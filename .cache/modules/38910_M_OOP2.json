{
  "id": 38910,
  "kuerzel": "M_OOP2",
  "bezeichnung": "Objektorientierte Programmierung 2",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n<li>Sie k&ouml;nnen fortgeschrittene Programmiertechniken von Java beschreiben und anwenden (File I/O, Serialisierung, Generics, Reflection, Annotations).</li>\n<li>Sie k&ouml;nnen Datenstrukturen beschreiben, implementieren und einsetzen (Arrays, Liste, Sets, Stack, Queue, Maps, B&auml;ume, Hash-basierte Datenstrukturen).</li>\n<li>Sie k&ouml;nnen grundlegende Such- und Sortieralgorithmen beschreiben, implementieren und analysieren.</li>\n<li>Sie k&ouml;nnen Verfahren zur Analyse der Laufzeitkomplexit&auml;t von Algorithmen beschreiben und vergleichen und mit der O-Notation einen gegebenen Algorithmus auf seine Komplexit&auml;t analysieren.</li>\n<li>Sie k&ouml;nnen ausgew&auml;hlte Design Patterns beschreiben und in passenden Anwendungsf&auml;llen implementieren (Iterator, Adapter, Visitor, Template Method).</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 38911,
      "kuerzel": "OOP2",
      "bezeichnung": "Objektorientierte Programmierung 2",
      "planinhalt": "<p><strong>Fortgeschrittene Programmiertechniken in Java:&nbsp; </strong></p>\n<ul>\n<li>File I/O &amp; Serialisierung&nbsp; &nbsp;</li>\n<li>Generische Programmierung</li>\n<li>Reflection-API</li>\n<li>Rekursive Programmierung</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Analyse von Algorithmen</strong></p>\n<ul>\n<li>Empirische Laufzeitmessung</li>\n<li>Komplexit&auml;ts-Analyse mit der O-Notation</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Grundlegende Such- und Sortieralgorithmen</strong></p>\n<ul>\n<li>Bin&auml;re Suche</li>\n<li>Insertionsort, Selectionsort, Heapsort</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Datenstrukturen</strong></p>\n<ul>\n<li>Arrays und Listen</li>\n<li>Stacks und Queues</li>\n<li>B&auml;ume (Traversierungen, Heaps)</li>\n<li>Hashing und Anwendungen (Map, Multimap, Hashtabellen)</li>\n<li>Sets, Multisets</li>\n<li>Fortgeschrittene Datensrukturen (z.B. Priority Queue, Deque)</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Design Patterns f&uuml;r Algorithmen und Datenstrukturen</strong></p>\n<ul>\n<li>Adapter</li>\n<li>Iterator</li>\n<li>Template Methode</li>\n<li>Visitor</li>\n</ul>",
      "bibliographie": "<p>Data Structures and Algorithms in Java</p>\n<p>International Student Version</p>\n<p>Goodrich/Tamassia/Goldwasser Wiley &amp; Sons Ltd</p>\n<p>ISBN : 978-1-118-80857-3&nbsp;</p>",
