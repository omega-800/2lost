  "kurse": [
    {
      "id": 46863,
      "kuerzel": "FaQ",
      "bezeichnung": "Faszination der Quanten - Konzepte und Anwendungen der modernen Physik",
      "kreditpunkte": 0,
      "lernziele": "<p>Die Studierenden</p>\n<ul>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">wissen, welche Fragestellungen und Experimente&nbsp;um 1900 eine neuen Theorie - die Quantentheorie - notwendig machten. </span></li>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">kennen die mit unserer Alltagserfahrung und damit der klassischen Physik im Widerspruch stehenden Schl&uuml;sselexperimente, die zum Ausl&ouml;ser der Entwicklung der Quantenmechanik wurden. </span></li>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">wissen, was Quantenobjekte sind und welche typischen Ph&auml;nomene Quantenobjekte zeigen. </span></li>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">k&ouml;nnen das Verhalten von Quantenobjekten in definierten experimentellen Situationen qualitativ beschreiben.</span> </li>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">erkennen bei Vorg&auml;ngen in der Natur und bei technischen Anwendungen die Grenzen der klassischen Physik. </span></li>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">kennen moderne technische Einsatzgebiete der Quantenmechanik.</span> </li>\n    <li style=\"TEXT-ALIGN: left; MARGIN: 6pt 3.4pt 0pt 0cm; mso-margin-top-alt: auto; mso-margin-bottom-alt: auto; mso-list: l0 level1 lfo1; tab-stops: list 36.0pt\" class=\"MsoNormal\"><span new=\"\">lernen an Beispielen die vielseitigen Anwendungen und Einsatzgebiete der Quantenphysik kennen.</span> </li>\n</ul>",
      "planinhalt": "<ul>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">Die Physik um 1900 und die Notwendigkeit einer neuen Theorie</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">Schr&ouml;dingers Gleichung und die Aufenthaltswahrscheinlichkeit</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">Quantenmechanisches Tunneln und das Rastertunnelmikroskop</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\"></span><span new=\"\">Der quantenmechanische Messprozess und Schr&ouml;dingers Katze</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">I</span><span new=\"\">nterferometrie und &bdquo;Welcher-Weg-Information&ldquo;</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">Heisenbergs Unsch&auml;rferelation und ihre Konsequenzen</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">Geheimnisvolle Verschr&auml;nkung und das EPR-Paradoxon</span></div>\n    </li>\n    <li>\n    <div style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\"></span><span new=\"\">Sichere Datenverschl&uuml;sselung durch Quantenkryptographie</span></div>\n    </li>\n    <li><span new=\"\">Computer versus Quantencomputer</span> </li>\n</ul>",
      "bibliographie": "<p style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt; tab-stops: list 36.0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\">Skript bzw. Vorlesungskopien&nbsp;&nbsp;</span></p>\n<p style=\"TEXT-ALIGN: left; MARGIN: 0cm 0cm 0pt; tab-stops: list 36.0pt\" class=\"MsoNormal\" align=\"left\"><span new=\"\"></span><span new=\"\">Buchempfehlung:&nbsp;&nbsp; Verschr&auml;nkte Welt : Faszination der Quanten / J&uuml;rgen Audretsch</span></p>",
