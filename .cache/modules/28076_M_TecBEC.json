{
  "id": 28076,
  "kuerzel": "M_TecBEC",
  "bezeichnung": "English: Where Tech Meets BEC",
  "kreditpunkte": 4,
  "lernziele": "<p>Das BEC Higher ist das Cambridge Business English Certificate, Stufe &bdquo;Higher&ldquo;.</p>\n<p>Designed for language levels B2 to C1, students</p>\n<ul>\n    <li>learn to critically reflect the representation of science and technology in the media today</li>\n    <li>are enabled to understand and analyse the role of technology in modern society</li>\n    <li>are capable of passing the BEC Higher examination.</li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 28077,
      "kuerzel": "TecBEC",
      "bezeichnung": "Where Tech Meets BEC: Technology in Society and How to Pass the BEC",
      "planinhalt": "<p>Key moments in the history of technology and science are explored, with a view to how cultural and social context determines scientific concepts and practices. <br />Precision and appropriateness of language is taught in a number of discourse situations, such as <br />- panel discussions <br />- project management roles<br />- making successful contributions at international committees and conferences. </p>\n<p>Students also receive the relevant input to pass BEC Higher, an external language certificate at C1 level by Cambridge University.&nbsp; <br /></p>",
      "kurselemente": [
        {
          "id": 28078,
          "art": "Vorlesung",
          "anzLektionen": 2,
          "maxTeilnehmer": 36,
          "harteGrenze": true
        },
        {
          "id": 28079,
          "art": "Uebung",
          "anzLektionen": 2,
          "maxTeilnehmer": 18,
          "harteGrenze": true
        }
      ],
