    {
      "id": 21608,
      "kuerzel": "SiedSo2",
      "bezeichnung": "Siedlungssoziologie 2",
      "lernziele": "<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Erkennen und Verstehen der Wirkungen der Architektur und der gebauten Umwelt auf Verhalten und Zufriedenheit der BewohnerInnen.</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Wissen um die Wohnbed&uuml;rfnisse von Menschen und Angeh&ouml;rigen sozial benachteiligter Gruppen.</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">F&auml;higkeit zu differenzierten und qualifizierten Aussagen zur Durchmischung der Wohnbev&ouml;lkerung.</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Kenntnisse des schweizerischen Wohnungsmarktes in bezug auf seine Angebote, Nachfrage, Tr&auml;ger, Entwicklungen und Zukunftstrends.</span></p>",
      "planinhalt": "<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Wohnbed&uuml;rfnisse und Soziologie des Wohnens</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Sozial benachteiligte Gruppen und ihre Wohnbed&uuml;rfnisse</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Soziale, ethnische und altersm&auml;ssige Durchmischung im Wohnbereich</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Beziehungen zwischen den Generationen, intergenerationelle Projekte und selbstst&auml;ndiges Wohnen im Alter</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Zukunftsweisende Wohn- bzw. Wohnungsangebote</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Pr&auml;sentation und Diskussion aktueller Forschungsprojekte</span></p>",
