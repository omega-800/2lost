{
  "id": 44124,
  "kuerzel": "M_IKNG_p",
  "bezeichnung": "Neue Narrative für eine nachhaltige Gesellschaft",
  "kreditpunkte": 3,
  "lernziele": "<p>Leitidee:</p>\n<p>Um den &ouml;kologischen Herausforderungen wie der Klimakrise oder dem drohenden Biodiversit&auml;tskollaps zu begegnen, m&uuml;ssen wir zwingend unsere Konsum- und Lebensstile &auml;ndern. Zur Entwicklung von Ans&auml;tzen f&uuml;r eine gelingende Ver&auml;nderung beleuchten wir die Hintergr&uuml;nde gesellschaftlicher Rahmenbedingungen, diskutieren &uuml;ber die Voraussetzungen f&uuml;r den notwendigen Wertewandel und elaborieren gemeinsam neue Narrative, die ein ressourcenleichtes Leben f&uuml;r alle erm&ouml;glichen.</p>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 44125,
      "kuerzel": "IKNG_p",
      "bezeichnung": "Neue Narrative für eine nachhaltige Gesellschaft ",
      "kreditpunkte": 0,
      "lernziele": "<p>Sachkompetenzen&nbsp;<br />Die Studierenden k&ouml;nnen: &nbsp;</p>\n<ul>\n<li>die Entstehung und Ver&auml;nderung gesellschaftlicher Werte beschreiben&nbsp;</li>\n<li>Einfluss von Narrativen auf die Entwicklung von gesellschaftlichen Werten und Normen aufzeigen&nbsp;</li>\n<li>Historische und aktuelle Narrative einordnen&nbsp;</li>\n<li>zur Entwicklung neuer Narrative, die einen ressourcenschonenden Konsum- und Lebensstil f&ouml;rdern, beitragen&nbsp;</li>\n</ul>\n<p>&nbsp;</p>\n<p>Selbstkompetenzen&nbsp;<br />Die Studierenden k&ouml;nnen: &nbsp;</p>\n<ul>\n<li>ihr eigenes Konsumverhalten reflektieren&nbsp;</li>\n<li>neue Ideen und Visionen glaubw&uuml;rdig pr&auml;sentieren und verargumentieren&nbsp;</li>\n</ul>\n<p>&nbsp;</p>\n<p>Sozialkompetenzen&nbsp;<br />Die Studierenden k&ouml;nnen:&nbsp;</p>\n<ul>\n<li>in einem interdisziplin&auml;ren Team arbeiten &nbsp;</li>\n<li>im interdisziplin&auml;ren Team neue Ideen entwickeln, die von den unterschiedlichen Perspektiven gepr&auml;gt sind&nbsp;</li>\n</ul>",
      "planinhalt": "<p>Lernblock I&nbsp;<br />&Ouml;kologische Herausforderungen&nbsp;</p>\n<ul>\n<li>Klima- &amp; Biodiversit&auml;tskrise</li>\n<li>globaler Fussabdruck&nbsp;</li>\n<li>&Ouml;kobilanz&nbsp;</li>\n</ul>\n<p><br />Lernblock II&nbsp;<br />Werte und Wandel&nbsp;</p>\n<ul>\n<li>individuelle und gesellschaftliche Werte&nbsp;</li>\n<li>Wertewandel&nbsp;</li>\n<li>Einflusspotenzial von Werten&nbsp;</li>\n</ul>\n<p><br />Lernblock III&nbsp;<br />Narrative&nbsp;</p>\n<ul>\n<li>Einordnung von Wirtschafts- und Gesellschaftsordnungen&nbsp;</li>\n<li>Entstehung und Ver&auml;nderung von Narrativen&nbsp;</li>\n<li>Einfluss von Narrativen&nbsp;</li>\n</ul>\n<p><br />Lernblock IV&nbsp;<br />Neue Narrative&nbsp;</p>\n<ul>\n<li>Entwicklung von Ideen f&uuml;r neue Narrative&nbsp;</li>\n<li>Elaborierung eines gemeinsamen Narratives&nbsp;</li>\n</ul>",
      "bibliographie": "",
      "empfLehrmittel": "<p>Theorie-Inputs, Plenumsdiskussionen und Gruppenarbeiten&nbsp;</p>",
      "bemerkungKurs": "",
      "leistungsnachweis": "<p>Pr&auml;sentation und aktive Teilnahme an Diskussion. Bewertung und Benotung der Projektvertiefung</p>",
