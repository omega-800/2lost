  "kurse": [
    {
      "id": 18267,
      "kuerzel": "RegioPol",
      "bezeichnung": "Regionalentwicklung und Standortpolitik",
      "lernziele": "<ul>\n    <li>Sie kennen wichtige Teile der Theorie der Regional&ouml;konomie</li>\n    <li>Sie kennen den Strukturwandel als Charakteristikum der wirtschaftlichen Entwicklung </li>\n    <li>Sie kennen die wichtigsten Faktoren f&uuml;r die Standortwahl von Unternehmungen </li>\n    <li>Sie kennen den Zusammenhang zwischen Strukturpolitik, Raumplanung und Standortwahl </li>\n    <li>Sie k&ouml;nnen die wichtigsten Standorttheoretischen Ans&auml;tze anwenden</li>\n</ul>",
      "planinhalt": "<ul>\n    <li>Wirtschaftsstruktur und Strukturwandel: Analyse der Wirtschaftsstruktur, Interpretation des Strukturwandels, Ziele und Instrumente der Strukturpolitik und ihre r&auml;umlichen Auswirkungen </li>\n    <li>Regionalwirtschaft, Neue Regionalplanung (NRP) und Neuer Finanzausgleich (NFA) </li>\n    <li>Standorttheorie und -Politik: Mobilit&auml;t der Produktionsfaktoren, Cluster, Milieu, Porter-Diamant, Economies of scope, economies of scale, Wachstumspol-Ansatz, ...........</li>\n    <li>Empirische Ueberpr&uuml;fung der Standorttheorie: unternehmerische Entscheidungsprozesse, St&auml;rken-/Schw&auml;chen-Profile, Standortportfolios, Unternehmensbefragungen </li>\n    <li>Projekt &quot;Standortattraktivit&auml;t und -entwicklung&quot;: Anwenden der theoretischen Kenntnisse an einem konkreten Projekt </li>\n</ul>",
