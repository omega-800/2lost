  "kurse": [
    {
      "id": 37370,
      "kuerzel": "Fest",
      "bezeichnung": "Festigkeitslehre",
      "lernziele": "<p><strong>Fachkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>die Begriffe Festigkeit und Steifigkeit erkl&auml;ren</li>\n<li>die verschiedenen Beanspruchungsarten unterscheiden</li>\n<li>einfache Bauteile dimensionieren</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Methodenkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>Beanspruchungen strukturieren und visualisieren</li>\n<li>kritische Belastungen an einfachen Bauteilen erkennen</li>\n<li>Berechnungsergebnisse mit Berechnungsingenieuren diskutieren</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Selbstkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>Verantwortung f&uuml;r Berechnungen mittragen</li>\n<li>mit den Grenzen und Unsch&auml;rfen der Festigkeitslehre umgehen.</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Sozialkompetenzen</strong>&nbsp;</p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>im Team mechanische Systeme dimensionieren</li>\n<li>Festigkeitsprobleme gesamtheitlich beschreiben</li>\n<li>bei Unklarheiten pr&auml;zise Fragen formulieren</li>\n</ul>",
      "planinhalt": "<p><strong>Themen-/Lernblock:</strong></p>\n<ul>\n<li>Grundlagen der Festigkeitslehre: Beanspruchungen</li>\n<li>Spannungs-Dehnungsdiagramm, E-Modul, Festigkeit</li>\n<li>Zug und Druck</li>\n<li>Biegung</li>\n<li>Torsion und Scherbeanspruchung</li>\n<li>Zusammengesetzte Beanspruchungen</li>\n<li>Festigkeitshypothesen</li>\n<li>Erm&uuml;dung: W&ouml;hlerkurven</li>\n<li>Instabilit&auml;t: Knicken, Beulen</li>\n</ul>",
      "bibliographie": "<p><strong>Pflichtliteratur wie Skript, B&uuml;cher </strong></p>\n<p>Vorlesungs- und &Uuml;bungsfolien von Pierre Jousset</p>\n<p>&nbsp;</p>\n<p>Technische Mechanik f&uuml;r Wirtschaftsingenieure<br />Gabbert; Raecke<br />Hanser<br />01.03.2013<br />Auflage: 8., aktualisierte Auflage 2021<br />EBook-ISBN: 9783446435957<br />Print-ISBN (Hardback): 9783446432536</p>\n<p>&nbsp;</p>",
