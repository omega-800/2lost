  "bezeichnung": "Electrical Energy Systems",
  "kreditpunkte": 3,
  "lernziele": "<p>Die Studierenden</p>\n<ul>\n<li>vertiefen Kenntnisse im Bereich elektrische Maschinen.</li>\n<li>vertiefen Kenntnisse im Bereich Photovoltaik.</li>\n<li>vertiefen Kenntnisse verschiedener elektrischer Energiespeicher.</li>\n</ul>",
  "vorausgKenntnisse": "Bachelor-Studium Systemtechnik mit Profil Elektronik und Regelungstechnik",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 53421,
      "kuerzel": "TuIT_EVA_1015-1",
      "bezeichnung": "Vertiefungsseminar Electrical Energy Systems",
      "kreditpunkte": 1,
      "lernziele": "<p>Die erg&auml;nzende Veranstaltung besteht aus drei Seminaren, welche im Rahmen des MSE im Bereich elektrische Energietechnik angeboten werden. </p>\n<p>Seminar 1: Auslegung und Simulation energieeffizienter Elektrischer Maschinen und Aktoren (Prof. Dr. A. Vezzini, BFH)</p>\n<ul>\n    <li>Vertiefte Kenntnisse im Bereich elektrische Maschinen </li>\n</ul>\n<p>Seminar 2: Leistungsfaktorkorrektur und -kontrolle (Prof. M. Carpita, HEIG VD (HES-SO))</p>\n<ul>\n    <li>Vertiefte Kenntnisse im Bereich Power Factor Correction.</li>\n</ul>\n<p>Seminar 3: Batterien, Supercaps und Integration (Prof. V. H&auml;rri, HSLU)</p>\n<ul>\n    <li>Vertiefte Kenntnisse verschiedener elektrischer Energiespeicher<br /></li>\n</ul>",
      "planinhalt": "<p>Seminar 1:</p>\n<ul>\n<li>Grundlagen der el. mag. Energieumwandlung</li>\n<li>Numerische Feldberechnungsverfahren</li>\n<li>Modellerstellung / Parameterwahl</li>\n<li>Simulation</li>\n</ul>\n<p>Seminar 2:</p>\n<ul>\n<li>\n<p>Energiespeicher Grundlagen</p>\n</li>\n</ul>\n<p>&nbsp; &nbsp; &nbsp;- Lade- und Entladekurven</p>\n<p>&nbsp; &nbsp; &nbsp;- Sicherer Betrieb, BMS (Battery Management System)</p>\n<p>&nbsp; &nbsp; &nbsp;- SOC (State of Charge), SOH (State of Helth)</p>\n<p>&nbsp; &nbsp; &nbsp;- Messungen im Labor</p>\n<ul>\n<li>\n<p>&nbsp;</p>\n<p>Elektromobilit&auml;t</p>\n</li>\n</ul>\n<p>&nbsp; &nbsp; &nbsp;- Antriebskonzepte<br />&nbsp; &nbsp; &nbsp;- Integration und Dimensionierung eines Speichers<br />&nbsp; &nbsp; &nbsp;- Messfahrten Teil 1</p>\n<ul>\n<li>Ladeinfrastruktur<br />- Integration Photovoltaik und Geb&auml;udespeicher<br />- Leistungsmessung im Labor<br />- Messfahrten Teil 2</li>\n</ul>\n<p>Seminar 3:</p>\n<ul>\n<li>Photovoltaik</li>\n</ul>",
      "empfLehrmittel": "<p>Vorlesung, </p>\n<p>&Uuml;bungen</p>",
      "bemerkungKurs": "Unterricht teilweise in Englisch",
      "leistungsnachweis": "<p>Dieser Kurs wird mit einer Pr&auml;sentation bewertet.</p>",
