  "bezeichnung": "Städtebau 6 / Freiraumplanung 3",
  "kreditpunkte": 4,
  "lernziele": "<p>Kennenlernen von st&auml;dtebaulichen Leitbildern und Ver&auml;nderungsprozessen im urbanen Raum im Zusammenhang mit ihren kulturellen, &ouml;konomischen und gesellschaftlichen Hinergr&uuml;nden</p>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 17065,
      "kuerzel": "StSem",
      "bezeichnung": "Städtebauseminar",
      "lernziele": "Seminaristische Erarbeitung von st&auml;dtebaulichen Schwerpunktthemen<br />Intensive Auseinandersetzung mit gesellschaftlichen Hintergr&uuml;nden des St&auml;dtebaus",
      "planinhalt": "<p>Ausgew&auml;hlte Seminarthemen aus folgenden Bereichen: </p>\n<ul>\n    <li>Aktuelle Leitbilder und&nbsp;Konzepte wie z.B.&nbsp;: Nachhaltige Stadt, Kompakte Stadt, Soziale Stadt, Stadt der kurzen Wege, Zwischenstadt, ... </li>\n    <li>Konzepte des Stadtumbaus und Stadtr&uuml;ckbaus </li>\n    <li>Aspekte der Agglomerationsentwicklung&nbsp;</li>\n</ul>",
      "kurselemente": [
        {
          "id": 17066,
          "art": "Seminar",
          "anzLektionen": 2,
          "maxTeilnehmer": 18,
          "harteGrenze": true
