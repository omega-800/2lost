  "kreditpunkte": 4,
  "lernziele": "<ul dir=\"ltr\">\n    <li>\n    <div style=\"MARGIN-RIGHT: 0px\">ganzen Innovationsprozess verstehen und in Zusammenhang zur Produktentwicklung stellen k&ouml;nnen</div>\n    </li>\n    <li>\n    <div style=\"MARGIN-RIGHT: 0px\">Produkt-Markt-Strategien kennen und die Methoden dazu anwenden k&ouml;nnen</div>\n    </li>\n    <li>\n    <div style=\"MARGIN-RIGHT: 0px\">Aspekte der Markteinf&uuml;hrung kennen</div>\n    </li>\n    <li>\n    <div style=\"MARGIN-RIGHT: 0px\">Stolpersteine &amp; Erfolgsfaktoren im Innovationsprozess kennen</div>\n    </li>\n    <li>\n    <div style=\"MARGIN-RIGHT: 0px\">Kennt den Zusammenhang von Innovation und Gesch&auml;ftsplanung</div>\n    </li>\n</ul>",
