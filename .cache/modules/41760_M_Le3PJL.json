  "kreditpunkte": 6,
  "lernziele": "<ul>\n<li>Selbst&auml;ndige Erarbeitung oder Aktualisierung eines informellen landschaftspolitischen Instruments im interdisziplin&auml;ren Team (L+SVR)</li>\n<li>Formen der Mitwirkung kennenlernen und unterscheiden k&ouml;nnen</li>\n</ul>",
  "vorausgKenntnisse": "<p>Keine</p>",
