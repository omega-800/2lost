    {
      "id": 57159,
      "kuerzel": "MEPD2_M",
      "bezeichnung": "Maschinenelemente II",
      "lernziele": "<p>Die Studierenden</p>\n<ul>\n<li>k&ouml;nnen Maschinenelemente anforderungsgerecht ausw&auml;hlen und kennen die wesentlichen Anwendungen und Einsatzbereiche&nbsp;</li>\n<li>k&ouml;nnen Maschinenelement berechnen und dimensionieren&nbsp;</li>\n<li>k&ouml;nnen grundlegende Gestaltungsprinzipien in der Konstruktion umsetzen&nbsp;</li>\n<li>kennen die M&ouml;glichkeiten der manuellen und softwaregest&uuml;tzten Berechnung im Konstruktionsprozess&nbsp;</li>\n</ul>",
      "planinhalt": "<p>Grundlagen und Berechnung ausgew&auml;hlter Maschinenelemente wie zum Beispiel:&nbsp;</p>\n<ul>\n<li>Elemente zur Verbindung von Welle und Nabe&nbsp;</li>\n<li>Zahnradgetriebe, Verzahnungen&nbsp;</li>\n<li>Riementriebe&nbsp;</li>\n<li>Kupplungen&nbsp;</li>\n<li>Federn&nbsp;</li>\n<li>Schrauben&nbsp;</li>\n<li>Schweissen&nbsp;</li>\n</ul>",
      "bibliographie": "<ul>\n<li>Eigene Skripte, Lernmaterialien und &Uuml;bungsunterlagen&nbsp;</li>\n<li>Roloff/Matek: Maschinenelemente, Vieweg</li>\n</ul>",
