  "kreditpunkte": 2,
  "lernziele": "<ul> <li>Einf&#252;hrung in die praktische Arbeit im Labor (Laborjournal, Fehlerrechung etc.)</li> <li>Selbst&#228;ndiges Arbeiten in Gruppen und F&#246;rderung der Sozialkompetenz. </li></ul>",
  "vorausgKenntnisse": "<p>anstelle von Chemie 1: Basischemie oder gleichwertige Kenntnisse</p>",
