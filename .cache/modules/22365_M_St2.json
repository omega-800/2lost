      "id": 22372,
      "kuerzel": "SiedSo2",
      "bezeichnung": "Siedlungssoziologie 2",
      "lernziele": "<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Erkennen und Verstehen der Wirkungen der Architektur und der gebauten Umwelt auf das Verhalten und Wohlbefinden der BewohnerInnen.</span></p>\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Wissen um die Wohnbed&uuml;rfnisse von Menschen und Angeh&ouml;rigen sozial benachteiligter Gruppen.</span></p>\n<span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Kenntnisse des schweizerischen Wohnungsmarktes in bezug auf seine Angebote, Tr&auml;ger, Entwicklungen und Zukunftstrends.</span></p>\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\">F&auml;higkeit zum selbstst&auml;ndigen Arbeiten und zur Anwendung des siedlungssoziologischen Wissens in gr&ouml;sseren raumplanerischen Projekten.</p>\n</span>",
      "planinhalt": "<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Wohnbed&uuml;rfnisse und Soziologie des Wohnens</span></p>\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Sozial benachteiligte Gruppen und ihre Wohnbed&uuml;rfnisse</span></p>\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Beziehungen zwischen den Generationen, intergenerationelle Projekte und selbstst&auml;ndiges Wohnen im Alter</span></p>\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Zukunftsweisende Wohn- bzw. Wohnungsangebote</span></p>\n<p style=\"LINE-HEIGHT: normal; MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\"></span><span style=\"FONT-FAMILY: ; FONT-SIZE: 10pt\">Gr&ouml;ssere selbstst&auml;ndige Projektarbeit in kleineren Gruppen</span></p>",
