  "kreditpunkte": 2,
  "lernziele": "<ul>\n<li>Daten aus Erhebungen und Experimenten statistisch auswerten</li>\n<li>Kennziffern und Parameter sch&auml;tzen</li>\n<li>statistische Hypothesen formulieren und testen</li>\n<li>statistische Erhebungen planen</li>\n<li>Wahrscheinlichkeitsexperimente simulieren</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 45183,
      "kuerzel": "StatDA",
      "bezeichnung": "Statistische Datenanalyse ",
      "lernziele": "<p>Die Studierenden</p>\n<ul>\n<li>verstehen statistische Konzepte der Datenverarbeitung (Stichproben, Kennzahlen, ...)</li>\n<li>k&ouml;nnen Parameter sch&auml;tzen&nbsp;</li>\n<li>k&ouml;nnen statistische Tests f&uuml;r praktische Problemstellungen ausw&auml;hlen, durchf&uuml;hren und die Resultate interpretieren</li>\n<li>k&ouml;nnen Daten und experimentelle Resultate aus unterschiedlichen Fachrichtungen ad&auml;quat statistisch interpretieren und Fehlinterpretationen erkennen bzw. vermeiden</li>\n<li>k&ouml;nnen statistische Resultate und Zusammenh&auml;nge korrekt formulieren</li>\n</ul>",
      "planinhalt": "<ul>\n<li>Empirische Verteilung einer Stichprobe</li>\n<li>Normalverteilung sch&auml;tzen und Wahrscheinlichkeiten berechnen</li>\n<li>Konfidenzintervalle f&uuml;r Erwartungswert, Standardabweichung und Anteil bestimmen</li>\n<li>Ein- und zweiseitige Einstich- und Zweistichproben t-Tests planen und durchf&uuml;hren</li>\n<li>Stichprobengr&ouml;sse bestimmen</li>\n<li>Chi-Quadrat-Test f&uuml;r diskrete Daten, Shapiro-Wilk-Test und Kolmogorow-Smirnow-Test</li>\n<li>Grundz&uuml;ge der statistischen Versuchsplanung</li>\n<li>Statistische Auswertungen und Simulationen</li>\n</ul>",
