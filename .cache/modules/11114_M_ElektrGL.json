  "kurse": [
    {
      "id": 10253,
      "kuerzel": "PhysElek",
      "bezeichnung": "Physik / Elektrizität ",
      "lernziele": "<p>Das Hauptgewicht liegt auf dem Verst&#228;ndnis der grundlegenden Eigenschaften von elektrischen und magnetischen <br />Erscheinungen. Es k&#246;nnen einfache Berechnungen mit elektrischen Bauteilen (Widerstand, Kondensator etc.) durchgef&#252;hrt werden</p> <p>&nbsp;</p>",
      "planinhalt": "<p>Einf&#252;hrung: Begriff der Ladung, Coulombsches Gesetz </p>\n<p>Elektrisches Feld: Entstehung des E-Feldes, Energie und Energiedichte des E-Feldes, elektrische Spannung und Potential, Feld und Potentialberechnungen f&#252;r einfache Geometrien. </p>\n<p>Materie im E-Feld: Dielektrikum, Kondensator. </p>\n<p>Elektrischer Strom: Transportmechanismen in Halbleitern, Metallen und Elektrolyten, Ohmsches Gesetz und Schaltungen von Widerst&#228;nden, RC-Kreise, Joulsche W&#228;rme. </p>\n<p>Magnetostatik: Begriff des Magnetfeldes, Energiedichte des Magnetfeldes, Entstehung von B-Feldern und magnetische Kr&#228;fte, Feldberechnungen bei einfachen Geometrien. </p>\n<p>Elektrodynamik: Induktionsgesetz, Induktivit&#228;ten, Transformator, Schwingkreise</p>",
      "kurselemente": [
