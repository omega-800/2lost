  "kurse": [
    {
      "id": 28336,
      "kuerzel": "ETEU",
      "bezeichnung": "Grundlagen Elektrotechnik",
      "lernziele": "<ul>\n<li>Grundlagen und Berechnungsverfahren der Gleich-, Wechsel- und Drehstromtechnik</li>\n<li>Messen elektrischer Gr&ouml;ssen</li>\n</ul>",
      "planinhalt": "<ol>\n<li>Sicherheit im Umgang mit der Elektrizit&auml;t (Personenschutz, Anlagenschutz, Vorschriften)</li>\n<li>Gleichstromtechnik&nbsp;&nbsp;&nbsp; <br />- Grundbegriffe: elektrischer Strom und elektrische Spannung, elektrischer <br />&nbsp; Widerstand,&nbsp;&nbsp;elektrische Leistung<br />- Kondensator und Induktivit&auml;t, Schaltvorg&auml;nge&nbsp;&nbsp;&nbsp; <br />- Kirchhoff'sche Gesetze und Berechnungsverfahren der Gleichstromschaltungen</li>\n<li>Elektromagnetismus</li>\n<li>Wechselstromtechnik&nbsp;&nbsp;&nbsp; <br />- Grundbegriffe: Periodendauer und Frequenz, Mittel-, Scheitel- und Effektivwerte,&nbsp;&nbsp;&nbsp;<br />&nbsp;&nbsp;Phasenverschiebungen, Formfaktoren&nbsp;&nbsp;&nbsp; <br />- Darstellung von Wechselgr&ouml;ssen: Liniendiagramme, Zeigerdiagramme, <br />&nbsp; Frequenzgang&nbsp;&nbsp;&nbsp; <br />- Komplexe Berechnung von Wechselgr&ouml;ssen&nbsp;&nbsp;&nbsp;<br />- Verbraucher im Wechselstromnetz: Berechnung, Schaltung und Kompensation&nbsp;&nbsp;&nbsp; <br />- Leistungen im Wechselstromsystem</li>\n<li>Drehstromsystem&nbsp;&nbsp;&nbsp;<br />- Entstehung, Begr&uuml;ndung, Eigenschaften&nbsp;&nbsp;&nbsp; <br />- Verketten der Str&ouml;me bzw. Spannungen&nbsp;&nbsp;&nbsp;&nbsp; <br />- Anwendungen der Stern- und Dreieckschaltung&nbsp;&nbsp;&nbsp; <br />- Leistungen im Drehstromsystem&nbsp;&nbsp;&nbsp; <br /><br /></li>\n</ol>\n<p>&nbsp;</p>",
