  "kreditpunkte": 4,
  "lernziele": "<ul>\n<li>Grundbegriffe Elektrisches Feld</li>\n<li>Grundlagen und Berechnungsverfahren der Gleich-, Wechsel- und Drehstromtechnik</li>\n<li>Messen elektrischer Gr&ouml;ssen</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
