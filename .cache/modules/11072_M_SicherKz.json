        }
      ]
    },
    {
      "id": 10184,
      "kuerzel": "GlProj",
      "bezeichnung": "Grundlagen der Projektierung von Tragwerken",
      "lernziele": "<p>&#8226; Verst&#228;ndnis f&#252;r den Umgang mit Berechnungsmodellen zur Gew&#228;hrleistung von Tragsicherheit und Gebrauchstauglichkeit von Bauwerken. <br />&#8226; Sicherheit in der Anwendung der Grundlagen der SWISSCODES (neue Normengeneration SIA 260 &#8211; 267) </p>",
      "planinhalt": "<p>&#8226; Projektierungselemente (Gef&#228;hrdungsbild, Nutzungszustand, Bemessungssituationen, Tragsicherheit, Gebrauchstauglichkeit) <br />&#8226; Einwirkungen auf Tragwerke, Last- und Reduktionsbeiwerte, Bemessungswerte <br />&#8226; Grenzzust&#228;nde der Tragsicherheit und der Gebrauchstauglichkeit </p>",
