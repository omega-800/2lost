{
  "id": 42332,
  "kuerzel": "M_VWBau2",
  "bezeichnung": "Verkehrswegebau 2: Projektierung von Strassenverkehrsanlagen",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n<li>Die Grundlagen der Strassenbauprojektierung lernen.</li>\n<li>Die materialtechnologischen und geotechnischen Aspekte des Verkehrswegebaus lernen.</li>\n<li>Strassen- und Pistenoberbauten sicher bemessen und projektieren.</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 42333,
      "kuerzel": "VWBau2",
      "bezeichnung": "Projektierung von Strassenverkehrsanlagen",
      "lernziele": "<ul>\n<li>Die Grundlagen der Strassenbauprojektierung lernen.</li>\n<li>Die materialtechnologischen und geotechnischen Aspekte des Verkehrswegebaus lernen.</li>\n<li>Strassen- und Pistenoberbauten sicher bemessen und projektieren.</li>\n</ul>",
      "planinhalt": "<p><span style=\"text-decoration: underline;\"><strong>Teil A):</strong></span></p>\n<ul>\n<li>Einf&uuml;hrung &uuml;ber den Strassenbau</li>\n<li>Baugrunduntersuchungen</li>\n<li>Verdichtung und mechanische Bodenstabilisierung</li>\n<li>Tragf&auml;higkeitsversuche im Verkehrswegebau</li>\n<li>Frost im Strassenbau: Theorie und praktisch Aspekte</li>\n<li>Bodenstabilisierung mit Kalk und Zement: Theorie, Dosierung, Effekte und Anwendungsbereiche</li>\n<li>Feste Fahrbahn (Betonplatten) und Flughafen Pisten: Bemessung, Ausf&uuml;hrung und Beispiele (Externer Referent)</li>\n<li>Fundation- und Tragschicht sowie Deckschicht: Materialienzusammensetzung, Ausf&uuml;hrung, Anforderungen und Pr&uuml;fmethoden. Fokus: Gesteinsk&ouml;rnungsgemische und Asphalt</li>\n<li>Bemessung des Strassenoberbaus nach der AASHTO und VSS-Methode (Frost und Tragf&auml;higkeit)</li>\n<li>Geotechnische Aspekte des Eisenbahnbaus (Externer Referent) &nbsp;</li>\n</ul>\n<p>&nbsp;</p>\n<p><span style=\"text-decoration: underline;\"><strong>Teil B):</strong></span><br><strong>Ausf&uuml;hrung:</strong></p>\n<ul>\n<li>&nbsp;Strassenoberbau</li>\n<li>&nbsp;Fundationen</li>\n<li>Asphaltbel&auml;ge</li>\n<li>Betonfahrbahnen</li>\n<li>Modulsysteme aus Beton-Fertigelementen</li>\n<li>Abschl&uuml;sse</li>\n<li>Pfl&auml;sterungen</li>\n<li>Oberfl&auml;chenbehandlung und Risssanierung</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Materialien</strong></p>\n<ul>\n<li>Materialien f&uuml;r die Ausf&uuml;hrung:</li>\n<li>Materialien f&uuml;r Asphaltbel&auml;ge</li>\n<li>Materialien f&uuml;r Naturstrassen</li>\n<li>Materialien f&uuml;r Abschl&uuml;sse und Pfl&auml;sterungen</li>\n<li>Geokunststoffe</li>\n<li>Aushub- und Abbruchmaterialien</li>\n<li>Baustoffkreislauf</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Verschiedenes:</strong></p>\n<ul>\n<li>Vermessungs- und Absteckarbeiten</li>\n</ul>",
