{
  "id": 42316,
  "kuerzel": "M_SWW1",
  "bezeichnung": "Siedlungswasserwirtschaft 1: Siedlungsentwässerung 1 und Wasserversorgung 1",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n<li>Die Studierenden verstehen die Bedeutung, die Aufgaben und die Funktionsweise der Siedlungswasserwirtschaft (Wasserversorgung, Abwasserentsorgung und &ndash;reinigung, oberirdische Siedlungsentw&auml;sserung) f&uuml;r die Umwelt und Gesellschaft.</li>\n<li>Sie sind in der Lage, ein System zu verstehen, zu beurteilen und allf&auml;lligen Handlungsbedarf zu erkennen.</li>\n<li>Sie kennen die Grundlagen der Siedlungswasserwirtschaft:\n<ul>\n<li>Hydrologie und Wasserkreislauf (global und siedlungsspezifisch)</li>\n<li>Niederschlags- und Abflussgr&ouml;ssen mit Auftretenswahrscheinlichkeiten</li>\n<li>Versagensrisiko und Dimensionierungsgr&ouml;ssen&nbsp;</li>\n</ul>\n</li>\n</ul>",
  "vorausgKenntnisse": "<p>keine</p>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 42317,
      "kuerzel": "SWW1Ent",
      "bezeichnung": "Siedlungsentwässerung 1",
      "lernziele": "<ul>\n<li>Gesetzliche Grundlagen Gew&auml;sserschutz</li>\n<li>Entw&auml;sserungsverfahren</li>\n<li>Bemessung Abwasseranfall\n<ul>\n<li>Trockenwetter</li>\n<li>Regenwassermengen</li>\n</ul>\n</li>\n<li>Bemessung Liegenschaftsentw&auml;sserung</li>\n<li>Bemessung von Freispiegelleitungen</li>\n<li>Entw&auml;sserungsplanung (GEP)</li>\n<li>Messverfahren</li>\n<li>Kanalisationsunterhalt</li>\n<li>Abwasserreinigung:\n<ul>\n<li>Ziele und Anforderungen</li>\n<li>Komponenten einer ARA mit ihren Funktionsweisen</li>\n<li>Organisation, Kosten und Finanzierung&nbsp;</li>\n</ul>\n</li>\n</ul>",
      "planinhalt": "<p>Siedlungsentw&auml;sserung:<br />&bull; Entw&auml;sserungsverfahren, technische Elemente, hydraulische Bemessung, Entw&auml;sserungsplanung (GEP, VGEP, REP)<br />&bull; Abwasserreinigung:<br />o Ziele und Anforderungen<br />o Komponenten einer ARA mit ihren Funktionsweisen<br />o Organisation, Kosten und Finanzierung</p>",
