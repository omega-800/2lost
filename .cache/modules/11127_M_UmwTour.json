          "id": 3701,
          "bezeichnung": "Umweltverträglichkeit Natur und Landschaft"
        },
        {
          "id": 3702,
          "bezeichnung": "Environmental Sustainability Nature and Landscape"
        }
      ]
    },
    {
      "id": 10269,
      "kuerzel": "NatTour",
      "bezeichnung": "Nachhaltiger bzw. naturnaher Tourismus",
      "lernziele": "<ul>\n    <li>F&auml;higkeit zur selbst&auml;ndigen Entwicklung einfacher touristischer Angeboten im Rahmen von raum- und landschaftsplanerischen Fragestellungen und Projekten </li>\n    <li>Methodische und praktische Kompetenz zur Bewertung touristischer Infrastrukturen/Angebote/Aktivit&auml;ten hinsichtlich den Zielen einer nachhaltigen Regionalentwicklung <br /></li>\n</ul>",
      "planinhalt": "<p>Grundz&#252;ge der Tourismus- und Freizeitlehre, Einf&#252;hrung in touristische Trends und Megatrends <br />Grundlagen und Instrumente der schweizerischen Tourismuspolitik <br />Touristische Planungsinstrumente, Methoden der touristischen Angebotsentwicklung sowie der (Naherholungs-)Nachfrage: <br />Ziele und Strategien des nachhaltigen Tourismus und des naturnahen Tourismus (mit Anwendungsbeispielen, z.B. Projekte des naturbased tourism aus dem In- und Ausland); Umsetzung von nachhaltigen Tourismuskonzepten mit Instrumenten der kommunalen, regionalen und kantonalen Planung <br /></p>",
      "kurselemente": [
