  "lernziele": "<p><u>Grammatik</u><br />Grundkenntnisse der chinesischen Hochsprache Mandarin </p>\n<p>&nbsp;</p>\n<p><u>Vokabular</u><br />Bis zu 200 </p>\n<p>&nbsp;</p>\n<p><u>Zeichen</u><br />50 bis100 </p>\n<p>&nbsp;</p>\n<p><u>Kommunikation und m&uuml;ndlicher Ausdruck</u><br />F&auml;higkeit einfache Alltagskonversation zu f&uuml;hren und zu verstehen</p>\n<p>&nbsp;</p>\n<p><u>Landeskunde</u><br />Kennen einiger Verhaltens- und Kommunikationsregeln des Privat- und Berufslebens in China<br />&nbsp; </p>",
  "vorausgKenntnisse": "keine\n<p>&nbsp;</p>",
