{
  "id": 56740,
  "kuerzel": "M_IKFL",
  "bezeichnung": "Future Life Design: Successfully shaping your own life path",
  "kreditpunkte": 2,
  "lernziele": "<p>The statistics speak for themselves: Around onethird of the working population in Switzerland feel on the verge of burnout, according to the Job Stress Index 2022. The Gallup Report 2024 reveals that only nine percent of people in Switzerland describe themselves as engaged at work. These figures suggest that many, especially younger individuals in Switzerland, struggle to find a fulfilling career path. They need a practical toolkit to shape their own future.</p>",
  "semesterBewertung": "bestanden / nicht bestanden",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 56741,
      "kuerzel": "IKFL",
      "bezeichnung": "Future Life Design: Successfully shaping your own life path",
      "kreditpunkte": 0,
      "lernziele": "<p><strong>Sachkompetenzen</strong><br /><em>Die Studierenden k&ouml;nnen:</em></p>\n<ul>\n<li>understanding and applying methods of selfawareness</li>\n<li>understanding and applying methods for goal<br />setting and action planning</li>\n<li>understanding and applying methods for focus<br />setting, habit formation, and managing uncertainty</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Selbstkompetenzen</strong><br /><em>Die Studierenden k&ouml;nnen:</em></p>\n<ul>\n<li>better understand and assess themselves,<br />their motivation, and their identity</li>\n<li>clearly articulate their vision for the future and<br />plan it through achievable steps</li>\n<li>navigate themselves more effectively through<br />stressful situations</li>\n</ul>\n<p><strong>Sozialkompetenzen</strong><br /><em>Die Studierenden k&ouml;nnen:</em></p>\n<ul>\n<li>better understand others in their specific life<br />situations and respond to them with greater<br />empathy</li>\n<li>provide support to others in challenging life<br />situations</li>\n</ul>",
      "planinhalt": "<p><strong>Lernblock I</strong><br /><em>Passion: Discover intrinsic motivators through</em><br /><em>self-awareness.</em></p>\n<ul>\n<li>Scientific Foundations</li>\n<li>The Future Design Approach</li>\n<li>Energy Map</li>\n<li>Primal Inclination</li>\n<li>Social Mirroring</li>\n<li>Narrative Identity</li>\n<li>PANAS (Positive and Negative Affect Scale)</li>\n<li>Role Suitability</li>\n</ul>\n<p><br /><strong>Lernblock II</strong><br /><em>Vision: Identify new paths through foresight </em><em>and planning.</em></p>\n<ul>\n<li>Mission &amp; Vision</li>\n<li>Odyssey Maps</li>\n<li>Resource &amp; Commitment Assessment</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Lernblock III</strong><br /><em>Concentration: Successfully implement life plans through focus setting and habit formation.</em></p>\n<ul>\n<li>Impact/Effort Matrix</li>\n<li>Habit Formation</li>\n<li>Effective Management of Uncertainty</li>\n</ul>",
      "empfLehrmittel": "<p>Individual and group work, theoretical lectures,<br />individual coaching, plenary discussions, individual<br />reflection work.</p>",
      "leistungsnachweis": "",
