{
  "id": 22222,
  "kuerzel": "M_InfSi1",
  "bezeichnung": "Informationssicherheit 1 - Grundlagen",
  "kreditpunkte": 4,
  "lernziele": "<p style=\"TEXT-INDENT: -18pt; MARGIN: 0cm 0cm 0pt 36pt; mso-layout-grid-align: none\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: Symbol; FONT-SIZE: 10pt\">&middot;<span style=\"mso-tab-count: 1\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><span style=\"FONT-FAMILY: \" new=\"\">Sie k&ouml;nnen Gr&uuml;nde f&uuml;r Informationssicherheitsmassnahmen identifizieren&nbsp;</span></p>\n<p style=\"TEXT-INDENT: -18pt; MARGIN: 0cm 0cm 0pt 36pt; mso-layout-grid-align: none\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" new=\"\"></span><span style=\"FONT-FAMILY: Symbol; FONT-SIZE: 10pt\">&middot;<span style=\"mso-tab-count: 1\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><span style=\"FONT-FAMILY: \" new=\"\">Sie beherrschen Vorgehensweisen zum Verbesserung der Informationssicherheit&nbsp;</span></p>\n<p style=\"TEXT-INDENT: -18pt; MARGIN: 0cm 0cm 0pt 36pt; mso-layout-grid-align: none\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" new=\"\"></span><span style=\"FONT-FAMILY: Symbol; FONT-SIZE: 10pt; mso-no-proof: yes\">&middot;<span style=\"mso-tab-count: 1\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><span style=\"FONT-FAMILY: \" new=\"\">Sie beherrschen Krypto-Grundlagen (Verschl&uuml;sselungsalgorithmen, Signatur, Zertifikat)&nbsp;</span></p>\n<p style=\"TEXT-INDENT: -18pt; MARGIN: 0cm 0cm 0pt 36pt; mso-layout-grid-align: none\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" new=\"\"></span><span style=\"FONT-FAMILY: Symbol; FONT-SIZE: 10pt; mso-no-proof: yes\">&middot;<span style=\"mso-tab-count: 1\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><span style=\"FONT-FAMILY: \" new=\"\">Sie verstehen die verschiedenen Authentifizierungsverfahren und -technologien</span></p>\n<p style=\"TEXT-INDENT: -18pt; MARGIN: 0cm 0cm 0pt 36pt; mso-layout-grid-align: none\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" new=\"\"></span><span style=\"FONT-FAMILY: Symbol; FONT-SIZE: 10pt; mso-bidi-font-family: 'Times New Roman'; mso-no-proof: yes; mso-fareast-font-family: 'Times New Roman'; mso-fareast-language: DE; mso-ansi-language: DE-CH; mso-bidi-language: AR-SA\">&middot;<span style=\"mso-tab-count: 1\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span></span><span style=\"FONT-FAMILY: \" new=\"\">Sie kennen die wichtigsten Begriffe und Produkte aus dem Sicherheitsbereich und k&ouml;nnen diese anhand aktueller Beispiele erkl&auml;ren</span></p>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 22223,
      "kuerzel": "InfSi1",
      "bezeichnung": "Informationssicherheit 1",
      "planinhalt": "<ul><li>Einf&uuml;hrung zur Informationssicherheit<br />-&nbsp;Ziele (Werte, Gefahren, Verletzlichkeiten, technische, rechtliche, wirtschaftliche Risiken)<br />-&nbsp;Vorgehen zur Verbesserung der Informationssicherheit (Sicherheitskonzepte, Standards/Best Practices, Gesetze)</li><li>Kryptologie Grundlagen<br />-&nbsp;Begriffe, Prinzipien, Informationstheorie<br />-&nbsp;Verschl&uuml;sselungsverfahren<br />-&nbsp;Digitale Signatur<br />-&nbsp;Zertifikate</li><li>Zugriffskontrolle (Identifikation, Authentisierung)<br />-&nbsp;Prinzipien der Authentisierung (Passwort, Zertifikat, Biometric Sensors, ..., Smart Card)</li><li>Beispiel: Web Security (SSL/TLS)</li><li>Beispiel: Mail Security</li><li>Der Inhalt wird nach Bedarf angepasst, um aktuelle Sicherheitsprobleme zu behandeln</li></ul><p>Lern- und Unterrichtsmethoden: Vorlesung mit &quot;Chats&quot; und Lernkontrollen, &Uuml;bungen am Computer (Security Lab)</p><p>Unterrichtsunterlagen: Folien mit Zusatztexten (Kommentar); Tutorials/Videos/White Papters; Online-Infos</p><p>&nbsp;</p>",
