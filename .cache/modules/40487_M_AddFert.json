  "kuerzel": "M_AddFert",
  "bezeichnung": "Additive Fertigung",
  "kreditpunkte": 2,
  "lernziele": "<ul>\n<li>&nbsp;Vertieften Einblick in die Welt der additiven Fertigung erhalten</li>\n<li>&nbsp;Grundbegriffe der Maschinensteuerungen von AM-Systemen kennen</li>\n<li>&nbsp;Datenaustausch und Datenaufbereitungs-Problematik kennen (Austausch &uuml;ber Systemgrenzen)</li>\n<li>&nbsp;Aufbau von Toleranzketten in der additiven Fertigung verstehen und beherrschen</li>\n<li>Normen und Zertifizierungen in der additiven Fertigung kennen</li>\n<li>Vollst&auml;ndige Prozesskette vom CAD zum produzierten Werkst&uuml;ck durchf&uuml;hren</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
