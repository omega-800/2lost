  "kreditpunkte": 2,
  "lernziele": "<ul>\n<li>Vermittlung der Grundlagen zur Ingenieurseismologie und des Verhaltens von Boden unter Erdbebeneinwirkung</li>\n<li>vereinfachte Erdbebenbemessungen geotechnischer Strukturen&nbsp;</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
