  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 17222,
      "kuerzel": "UD1",
      "bezeichnung": "Urban Design 1",
      "lernziele": "<p>Kennenlernen des Stadtgef&uuml;ges und seiner wesentlichen Elemente und Nutzungen<br />Auseinandersetzung mit Stadtmorphologie und Stadtgestalt<br /><br /></p>",
      "planinhalt": "<p>Das Wesen der Stadt: kurzer geschichtlicher Abriss &uuml;ber die traditionelle Stadt. Die Stadt der Moderne.</p>\n<p>St&auml;dtebaugenerationen der Nachkriegszeit</p>\n<ul>\n    <li>Wesentliche Prinzipien: Urbanit&auml;t, Dichte, Oeffentlichkeit, Funktion, Nutzung und Organisation, usw. </li>\n    <li>Bausteine: Parzelle, Baufelder, Grenzbetrachtungen, Hauptstrukturierungs- und Gestaltungselemente, usw. </li>\n</ul>\n<p>Stadtmorphologie, Stadtform, Stadtstruktur</p>\n<ul>\n    <li>Stadtgrundriss </li>\n    <li>Stadtraumschichten (Stadtmitte, Stadxtrand) </li>\n    <li>Stadttopographie, Bau-, Freiraum-, Erschliessungs- und Infrastrukturen </li>\n</ul>\n<p>Stadtgestalt und Stadtbild (Kevin Lynch)</p>\n<p>Mensch und Umwelt</p>\n<ul>\n    <li>Bed&uuml;rfnisse, Wahrnehmung </li>\n    <li>Privatheit und Oeffentlichkeit, Gemeinschaft, Nachbarschaft </li>\n    <li>Ruhe und Bewegung, usw. </li>\n</ul>\n<p>Wohnen und Arbeiten (erg&auml;nzend zu den Modulen St1A1 und St2A2)</p>\n<p>&nbsp;</p>",
