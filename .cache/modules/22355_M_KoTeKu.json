  "kuerzel": "M_KoTeKu",
  "bezeichnung": "Kommunikation im Team und zwischen Kulturen",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Grundlagen der Teamarbeit kennen lernen (Wir als Team) </li>\n    <li>Individuelle Teamkompetenz optimieren (Ich im Team) </li>\n    <li>Grundlagen interkultureller Kommunikation kennen lernen </li>\n    <li>Erweitern des individuellen Handlungsrepertoires in interkulturellen Kommunikationssituationen </li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 22356,
      "kuerzel": "KoTeKu",
      "bezeichnung": "Kommunikation im Team und zwischen Kulturen",
      "lernziele": "<p><strong>Grundlagen Teamarbeit:</strong></p>\n<ul>\n<li>Sie sind f&auml;hig, Prozesse der Teambildung und Teamentwicklung zu erkennen und die Teamprozesse gemeinsam zu gestalten</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Individuelle Teamkompetenz</strong>:</p>\n<ul>\n<li>Sie sind f&auml;hig, die Teamprozesse mit Ihrem pers&ouml;nlichen Verhalten aktiv zu gestalten.</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Interkulturelle Kommunikation</strong>:</p>\n<ul>\n<li>Sie entwickeln Sensibilit&auml;t f&uuml;r die Kulturbedingtheit der eigenen und fremden Kommunikationsgewohnheiten</li>\n<li>Sie verstehen die psychologische Dynamik interkultureller Kommunikationssituationen</li>\n<li>Sie sind in der Lage, mit Personen aus anderen Kulturkreisen produktiv zusammen zu arbeiten</li>\n</ul>",
      "planinhalt": "<p><strong>Teamentwicklungsprozess:</strong></p>\n<ul>\n<li>Teambildung</li>\n<li>Teamphasen und Teamrollen</li>\n<li>Temeffektivit&auml;t</li>\n<li>Konfliktmanagement: Argumentieren und Verhandeln (m&uuml;ndlisch und schriftlich)</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Interkulturelle Kommunikation:</strong></p>\n<p>Entwicklung interkultureller Sensibilit&auml;t</p>\n<p>Reflexion eigener und fremder kultureller Werte und Normen und ihre Auswirkungen auf die berufliche Zusmmenarbeit</p>\n<p>Dynamik interkultureller Kommunikationssituationen:</p>\n<ul>\n<li>Stereotypen und Vorurteilsbildung, Beurteilungsfehler, Kommunikations-, Verhandlungs- und Konfliktstile</li>\n<li>Kulturangemessenheit des Methodeneinsatzes, z.B. bei partizipativen Verfahren</li>\n<li>Migration und Identit&auml;tsentwicklung</li>\n<li>Kennen lernen von Methoden zur Beschreibung von Kulturen, z.B. Kulturdimensionen, Kulturstandards, Kulturstile</li>\n</ul>\n<p>Erweiterung des eigenen Handlungsrepertoires</p>\n<p>Interkulturelle Kommunikationssituationen produktiv gestalten, z.B. Rahmen von realit&auml;tsgerechten Rollenspielen bzw. innerhalb der Projektarbeit</p>",
