  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Kennt die energetischen Zusammenh&auml;nge in der Schweiz.</li>\n    <li>Kann Energiesysteme bilanzieren.</li>\n</ul>\n<p>------------------</p>\n<ul>\n    <li>Kennt, berechnet und konstruiert W&auml;rmeaustauscher inklusive Verdampfer und Kondensatoren<br /></li>\n</ul>",
  "vorausgKenntnisse": "<p>Technische Mechanik 1&nbsp;- 3<br />Physik 2&nbsp; <br /></p>\n<p>&nbsp;</p>",
  "semesterBewertung": "keine Note oder Wertung",
