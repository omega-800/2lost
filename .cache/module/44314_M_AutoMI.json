          "maxTeilnehmer": 12,
          "harteGrenze": true
        }
      ],
      "uebersetzungen": [
        {
          "id": 3701,
          "bezeichnung": "Messtechnik"
        },
        {
          "id": 3702,
          "bezeichnung": "Measurement Engineering"
        }
      ]
    },
    {
      "id": 44319,
      "kuerzel": "SteuerT",
      "bezeichnung": "Steuerungstechnik",
      "lernziele": "<p>Die Teilnehmer k&ouml;nnen:<br />- die Steuerung von automatisierten Systemen, wie z.B. PLC, entwerfen und umsetzen<br />- die Funktion eines Steuerungssystems zu verstehen<br />- Systeme als Blockdiagramm und Zustandsdiagramm entwerfen und darstellen<br />- Logik- und Prozesssteuerungen entwerfen und umsetzen<br />- Strukturierten Text als Programmiersprache f&uuml;r SPS-Systeme aktiv nutzen<br />- Sichere Steuerungssysteme entwerfen und realisieren</p>",
      "planinhalt": "<p>In diesem Kurs lernen die Teilnehmer die Grundlagen des Entwurfs und der Implementierung eines Steuerungssystems auf der Basis von SPS und strukturiertem Text. Dar&uuml;ber hinaus werden die Grundlagen des Entwurfs und der Implementierung mit Hilfe von Programmiertechniken ausf&uuml;hrlich vermittelt und in einer Laborumgebung umgesetzt.</p>",
