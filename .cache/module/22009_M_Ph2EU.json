  "kurse": [
    {
      "id": 22010,
      "kuerzel": "Ph2EU",
      "bezeichnung": "Hydro- Aeromechanik und Thermodynamik",
      "lernziele": "<p>Beschreibung der Eigenschaften eines bewegten Fluids.<br />Verst&auml;ndnis der Temperatur und deren Bedeutung<br />Energie und Entropie. Wichtigkeit f&uuml;r Technik und Umwelt<br />Mechanismen des W&auml;rmetransports<br />Phasen&uuml;berg&auml;nge und thermodynamische Prozesse</p>",
      "planinhalt": "<ol>\n    <li><strong>HydroAero</strong>: Druck (physikalischer Ursprung, Herleitung und Bedeutung), Schweredruck, Druckverteilung in der Atmosph&auml;re, Auftrieb (statisch und dynamisch), Energiebetrachtungen (Bernoulli, Leistung einer Turbine bzw. eines Windkraftwerks, Leistungsbeiwert von Betz), Str&ouml;mungswiderstand, Cw-Wert. </li>\n    <li><strong>Thermodynamik:</strong>&nbsp; Zustandsgleichungen: Allgemein, Ideale Gase, Reale Gase. Thermodynamische Phasen und Phasen&uuml;berg&auml;nge, Dampfdruck, Schmelzdruck, Luftfeuchtigkeit.<br />Kinetische Gastheorie: mittlere freie Wegl&auml;nge, Diffusion, Herleitung der Transportkoeffizienten, Herleitung der Transportgleichungen.<br />W&auml;rmetransport: Konvektion, W&auml;rmeleitung, Strahlung<br />Energie und Entropie: Die Haupts&auml;tze der Thermodynamik<br />Zustands&auml;nderung und Kreisprozesse (Carnotscher Prozess, W&auml;rmepumpen, Stirling- und Verbrennungsmotor)&nbsp; <br /></li>\n</ol>",
