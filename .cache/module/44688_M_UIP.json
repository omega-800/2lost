{
  "id": 44688,
  "kuerzel": "M_UIP",
  "bezeichnung": "UI Patterns and Frameworks",
  "kreditpunkte": 4,
  "lernziele": "<p>&nbsp;Die Studierenden k&ouml;nnen:</p>\n<ul>\n<li>F&uuml;r User Interfaces (UI) relevante Architektur- und Software Design Patterns erkl&auml;ren und anwenden</li>\n<li>Die Implementation von UI-Patterns anhand aktueller Webframeworks analysieren und verstehen</li>\n<li>Grundkonzepte eines Multiplattform-Applikationsframeworks (am Beispiel von .NET MAUI) anwenden und erkl&auml;ren&nbsp;</li>\n</ul>",
  "vorausgKenntnisse": "<ul>\n<li>Grundlagen zu objektorientierter Programmierung (z.B. durch OOP1, OOP2 und AlgDat)</li>\n<li>Grundlagen in Web Programmierung (z.B. durch WE1)</li>\n<li>Grundkenntnisse von .NET / C# (Paralleler oder vorg&auml;ngiger Besuch von MsTe empfohlen)</li>\n<li>Englisch&nbsp;</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 44689,
      "kuerzel": "UIP",
      "bezeichnung": "UI Patterns and Frameworks",
      "planinhalt": "<p><strong>Teil 1: UI Architektur &amp; Patterns</strong></p>\n<ul>\n<li>Trennung von Darstellung und Logik</li>\n<li>Dependency Inversion Principle</li>\n<li>Markup, Template Engines, SSR, Transpile Markup Language anhand von JSX</li>\n<li>Grundlegende Design Patterns der GUI-Entwicklung (Observer, Mediator, MVC, MVP, MVVM) in Webapplikationen mit Typescript</li>\n<li>Funktionale UI Patterns in React</li>\n<li>State Container (Redux) und MVU Pattern</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Teil 2: Cross-Plattform Applikationen mit .NET MAUI</strong></p>\n<ul>\n<li>Grundlagen zu .NET und C#</li>\n<li>Anwendung der im ersten Teil kennengelernten Pattern in .NET MAUI</li>\n<li>Entwicklung von .NET MAUI-Applikationen</li>\n<li>Verwendung von .NET MAUI f&uuml;r Desktop und Mobile</li>\n<li>Ausblick: Weitere XAML-basierte UI-Frameworks in .NET (WPF, Xamarin, ...)&nbsp;</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>&Uuml;bergreifende Themen</strong></p>",
