      "planinhalt": "<p style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Die Wirtschaft ist der gr&ouml;sste Anwendungsbereich der Informatik. Im Modul Wirtschaftsinformatik 2 werden wir dieses Potential erkennen und folgende Themen behandeln: </span></p>\n<ul>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Modellierung von Gesch&auml;ftsprozessen</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Ereignisgesteuerte Prozessketten, BPMN</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Optimierung und Umsetzung von Gesch&auml;ftsprozessen</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Ethische, soziale und politische Fragen</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Trends der Wirtschaftsinformatik</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Wirtschaftsthemen</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Fallstudien</span></div>\n    </li>\n    <li>\n    <div style=\"MARGIN: 0cm 0cm 0pt; mso-margin-top-alt: auto\" class=\"MsoNormal\"><span style=\"FONT-FAMILY: \" lang=\"DE\">Gastreferate\n    <p>&nbsp;</p>\n    </span></div>\n    </li>\n</ul>",
