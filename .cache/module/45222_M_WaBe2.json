  "kurse": [
    {
      "id": 45223,
      "kuerzel": "WaBe2",
      "bezeichnung": "Wasseraufbereitung 2",
      "lernziele": "Siehe Modulbeschreibung",
      "planinhalt": "<p><strong>Vorlesung:</strong></p>\n<ul>\n<li>Strategien f&uuml;r die Untersuchung von Wasser-/Feststoffproben: Probenahme, Konservierung, Aufbereitung und Probenvorbereitung.</li>\n<li>Verfahren zur Entfernung von gel&ouml;sten Schadstoffen aus Ab- und Trinkwasser.</li>\n<li>Verfahren der Trinkwasseraufbereitung (Grund-, Oberfl&auml;chenwasser), spezifische Schadstoffe und Qualit&auml;tsparameter &middot;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Modellierung hydrologischer Systeme bei der urbanen Regenwasserbewirtschaftung.</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Exkursion: </strong></p>\n<ul>\n<li>Wasserversorgung.</li>\n</ul>\n<p>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</p>\n<p><strong>Praktikum: </strong></p>\n<ul>\n<li>Labor&uuml;bungen zur Trinkwasserdesinfektion und Probenahme &ndash; Beprobung (Boden- / Abwasserbelastung).&nbsp;&nbsp;</li>\n<li>Anwendung technischer Verfahren und stoffliche Bilanzierung mittels Analysen.&nbsp;</li>\n</ul>\n<p>&nbsp;</p>",
