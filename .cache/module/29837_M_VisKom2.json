{
  "id": 29837,
  "kuerzel": "M_VisKom2",
  "bezeichnung": "Visuelle Kommunikation 2",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Vermittlung differenzierter Darstellungsmethoden f&uuml;r spezielle fachliche Entwurfs- und Planungsaufgaben</li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 29838,
      "kuerzel": "Grafik2",
      "bezeichnung": "Typografie-Layout--Farbe-2",
      "lernziele": "<ul><li>Intensivieren und Festigen der grafischen Gestaltung</li><li>Grundkenntnisse der grafischen Gestaltung mit digitalen Medien</li><li>Anwendung und Vertiefung von Indesign und Photoshop</li></ul>",
      "planinhalt": "<p>Im Kurs besch&auml;ftigen wir uns mit weiteren Medien, wie die grafische Gestaltung einer Beamer-Pr&auml;sentation oder einer digitalen Dokumentation. Es werden noch weitere Themen, wie eigenes Gestaltungskonzept, Farbpaletten, Schraffuren, Texturen und Piktogramme erg&auml;nzt.</p><p>&nbsp;</p>",
      "kurselemente": [
        {
          "id": 29839,
          "art": "Praktikum",
          "anzLektionen": 2,
          "maxTeilnehmer": 16,
          "harteGrenze": true
        }
      ],
      "uebersetzungen": [
        {
          "id": 3701,
          "bezeichnung": "Typografie-Layout--Farbe-2"
        },
