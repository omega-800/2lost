{
  "id": 42231,
  "kuerzel": "M_NIoSec",
  "bezeichnung": "Network and IoT Security",
  "kreditpunkte": 4,
  "lernziele": "<p>Students will be able to</p>\n<ul>\n<li>explain and practically apply the network security protocols currently used on the different layers of the OSI communication model</li>\n<li>describe the modern concepts of network access control and put them into practice</li>\n<li>explain and practically apply the approaches to secure IoT against common attacks&nbsp;</li>\n</ul>",
  "vorausgKenntnisse": "",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 42232,
      "kuerzel": "NISec",
      "bezeichnung": "Network and IoT Security",
      "planinhalt": "<ul>\n<li>Network security\n<ul>\n<li>Physical Layer (quantum cryptography, generation of true random numbers)</li>\n<li>Link Layer (MAC, WLAN, 802.1X, mobile security)</li>\n<li>Network Layer (Virtual Private Networks, IPsec, DNSSEC, VoIP security)</li>\n<li>Anonymization methods on the Internet</li>\n</ul>\n</li>\n<li>Network access control\n<ul>\n<li>Firewalls, Intrusion Detection/Prevention Systems</li>\n<li>Network Endpoint Assessment, Trusted Network Connect, Network Access Protection</li>\n</ul>\n</li>\n<li>IoT Security\n<ul>\n<li>Attacks and defence approaches</li>\n<li>Content will be adjusted as needed to respond to current trends.&nbsp;</li>\n</ul>\n</li>\n</ul>",
