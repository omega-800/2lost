{
  "id": 11101,
  "kuerzel": "M_OeMod",
  "bezeichnung": "Öffentlichkeitsarbeit und Moderation",
  "kreditpunkte": 4,
  "lernziele": "<ul> <li>Auf der Basis der wichtigsten Partizipationsmodelle lernen sie, Gruppen zu steuern und zu gemeinsamen L&#246;sungen zu f&#252;hren.</li> <li>Bedeutung der Oeffentlichkeitsarbeit in der Raumplanung, Freiraumgestaltung und Landschaftsentwicklung kennen</li></ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 10237,
      "kuerzel": "OeArb",
      "bezeichnung": "Öffentlichkeitsarbeit",
      "lernziele": "<ul>\n    <li>Die wichtigsten Mittel und Methoden zur Information und Mitwirkung kennen</li>\n    <li>Die Kommunikation mit Beteiligten und Betroffenen konzipieren</li>\n    <li>Informationsmittel wie Pressetexte und Flyer verfassen und gestalten</li>\n</ul>",
      "planinhalt": "<p>Konzeption der Oeffentlichkeitsarbeit:</p>\n<ul>\n    <li>Grunds&auml;tzte, Ziel und Strategien der Oeffentlichkeitsarbeit</li>\n    <li>Dialoggruppen bestimmen, einbeziehen und gezielt ansprechen</li>\n    <li>Analyse von Kommunikationsaufgaben und Entwicklung von Strategien (Ziele, Botschaften, Vorgehen) anhand von Fallbeispielen und Semesterarbeiten/Arbeiten aus dem Blockunterricht</li>\n</ul>\n<p>Information:</p>\n<ul>\n    <li>Redaktion und Gestaltung von Informationsmitteln (Pressetexte, Berichte, Flyer, Internetauftritte) anhand von Fallbeispielen und Semesterarbeiten/Arbeiten aus dem Blockunterricht</li>\n    <li>Zusammenarbeit mit den Medien, Medienkategorien, Zeitungsproduktion, Presseversand, Medienkonferenzen</li>\n</ul>\n<p>Mitwirkung:</p>\n<ul>\n    <li>Mitwikrungsverfahren, Erfordernis nach Raumplanungsgesetz und Methoden zur Durchf&uuml;rhung</li>\n    <li>Kooperative Planungsprozesse anhand eines Beispiels aus der Praxis</li>\n</ul>",
      "kurselemente": [
        {
          "id": 10669,
          "art": "Vorlesung",
          "anzLektionen": 2,
          "maxTeilnehmer": 36,
          "harteGrenze": true
        }
      ],
      "uebersetzungen": [
        {
          "id": 3701,
          "bezeichnung": "Öffentlichkeitsarbeit"
        },
        {
          "id": 3702,
          "bezeichnung": "Public Relations"
        }
      ]
    },
    {
      "id": 10238,
      "kuerzel": "Mod",
      "bezeichnung": "Moderation",
      "lernziele": "<ul>\n    <li>Der Kurs vermittelt den Aufbau von sozialer Kompetenz</li>\n    <li>Sie lernen Arbeitsgruppen auf der SAch- und Prozessebene zu steuern</li>\n    <li>Sie beherrschen die Moderations-Methode in schwierigen Situationen</li>\n</ul>",
      "planinhalt": "<p>Schwergewichte sind &quot;Trainings&quot; zur Gestaltung von Beziehungen, zur Anwendung der Grundlagen der Kommunikation , sowie der F&auml;higkeit gemeinsam akzeptierte Entscheidungen zu finden.</p>\n<ul>\n    <li>Theorie und praktische Anwendung der Moderations-Methode</li>\n    <li>Verhandlungsf&uuml;hrung, Konflikte und Konfliktregelung, Entscheidung und Konsensfindung</li>\n    <li>Interventionstechniken, K&ouml;rp&uuml;ersprache, Metakommunikation</li>\n    <li>Beachten der Konsequenzen von Entscheidungen auf &ouml;konomischer, gesellschaftlicher, &ouml;kologischer und ethischer Ebene</li>\n</ul>",
