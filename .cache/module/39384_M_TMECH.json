  "kurse": [
    {
      "id": 39385,
      "kuerzel": "TMECH",
      "bezeichnung": "Technische Mechanik (WING)",
      "lernziele": "<p><strong>Fachkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>einfache mechanische Systeme durch ein berechenbares Modell beschreiben</li>\n<li>die am System wirkenden Lasten und Reaktionen beschreiben</li>\n<li>an einem System im Gleichgewicht die von aussen wirksamen Kr&auml;fte und Momente bestimmen</li>\n<li>an einem System im Gleichgewicht die im System wirkenden inneren Kr&auml;fte und Momente bestimmen</li>\n</ul>\n<p>&nbsp; &nbsp; &nbsp;Als System werden 2-dimensionale und einfache 3-dimensionale Systeme verstanden</p>\n<p>&nbsp;</p>\n<p><strong>Methodenkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>mechanische Ph&auml;nomene im Alltag und in technischen Anwendungen erkennen</li>\n<li>die geeigneten Methoden zur Bestimmung der mechanischen Gr&ouml;ssen w&auml;hlen</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Selbstkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>Verantwortung f&uuml;r die statische Berechnung von mechanischen Systemen mittragen</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Sozialkompetenzen</strong></p>\n<p>Die Teilnehmenden k&ouml;nnen:</p>\n<ul>\n<li>mit Entwicklungs- und Berechnungsingenieuren, sowie mit Kunden und Lieferanten mechanische Problemstellungen beschreiben und diskutieren</li>\n</ul>",
      "planinhalt": "<p><strong>Themen-/Lernblock: Statik</strong></p>\n<ul>\n<li>Grundlagen</li>\n<li>Ebenes Kraftsystem, Gleichgewicht von Kr&auml;ften, Lasten und Momenten</li>\n<li>einfache 3-dimensionale Systeme</li>\n<li>Freiheitsgrade, Lagerungen</li>\n<li>Seilreibung</li>\n<li>Massenschwerpunkt, Fl&auml;chenmoment</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Themen-/Lernblock: Innere Kr&auml;fte und Momente</strong></p>\n<ul>\n<li>Einf&uuml;hrung in die Balkentheorie, Schnittgr&ouml;ssen</li>\n</ul>",
      "bibliographie": "<p><strong>Pflichtliteratur wie Skript, B&uuml;cher</strong></p>\n<ul>\n<li>Techn. Mechanik f&uuml;r Wirtschaftsingenieure, Carl Hanser Verlag, ISBN 978-3-446-43253-6. Inhalt Statik, Festigkeitslehre und Dynamik (als Erg&auml;nzung zur Vorlesung)</li>\n<li>Skript</li>\n<li>&Uuml;bungen zur Theorie</li>\n</ul>",
