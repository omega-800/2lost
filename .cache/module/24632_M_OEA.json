  "kurse": [
    {
      "id": 24633,
      "kuerzel": "OeA",
      "bezeichnung": "Öffentlichkeitsarbeit",
      "lernziele": "<ul>\n<li>Den Zusammenhang zwischen Projektarbeit und &Ouml;ffentlichkeitsarbeit kennen</li>\n<li>Die wichtigsten Mittel und Methoden zur Information und Mitwirkung in der &Ouml;ffentlichkeitsarbeit kennen</li>\n<li>Die Kommunikation mit Beteiligten und Betroffenen konzipieren</li>\n<li>Kommunikationsmittel verfassen und gestalten</li>\n</ul>",
      "planinhalt": "<p>Konzeption der &Ouml;ffentlichkeitsarbeit:</p>\n<ul>\n<li>Grunds&auml;tze, Ziel und Strategien der &Ouml;ffentlichkeitsarbeit</li>\n<li>Dialoggruppen bestimmen, einbeziehen und gezielt ansprechen</li>\n<li>Kommunikationsaufgaben und Entwicklung von Strategien in der &Ouml;ffentlichkeitsarbeit (Ziele, Botschaften, Vorgehen) anhand von Fallbeispielen analysieren</li>\n</ul>\n<p>Kommunikationsmittel:</p>\n<ul>\n<li>Grundlagen zur Ausarbeitung von Kommunikationsmitteln (Pressetexte, Berichte, Flyer, Internetauftritte) anhand von Fallbeispielen kennen und gestalten</li>\n<li>Bedeutung der Zusammenarbeit mit den Medien kennenlernen und gestalten</li>\n</ul>\n<p>Mitwirkung:</p>\n<ul>\n<li>Mitwirkungsverfahren, Erfordernis nach Raumplanungsgesetz und Methoden zur Durchf&uuml;hrung von weiteren partizipativen Verfahren</li>\n<li>Kooperative Planungsprozesse anhand eines Beispiels aus der Praxis</li>\n</ul>",
