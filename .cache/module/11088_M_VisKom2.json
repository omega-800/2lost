  "bezeichnung": "Visuelle Kommunikation 2",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Vermittlung differenzierter Darstellungsmethoden f&uuml;r spezielle fachliche Entwurfs- und Planungsaufgaben</li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 10214,
      "kuerzel": "Typo2",
      "bezeichnung": "Typografie-Layout-Farbe-2",
      "lernziele": "<ul>\n    <li>Kenntnisse &uuml;ber die&nbsp;Gestaltungsmittel Farbe, Form und Komposition&nbsp;in der&nbsp;zweidimensionalen Gestaltung</li>\n</ul>",
      "planinhalt": "<p>Vertiefung in unterschiedliche Darstellungsmethoden. Projektbezogene Anwendungen f&uuml;r den Entwurfs- und Planungsunterricht. Erarbeiten eines Planlayouts. Einblicke in die Farbenlehre, Farbe und deren Beziehungen untereinander, Farbstimmungen und Farbwirkungen. Erarbeitung eines mehrseitigen Layouts.<br />Anwendungsorientierte Vertiefung in g&auml;ngige Layoutprogramme (z.B. InDesign).<br />4 Lektionen alle 2 Wochen.<br /></p>\n<p>&nbsp;</p>",
      "kurselemente": [
        {
          "id": 12377,
          "art": "Praktikum",
          "anzLektionen": 2,
          "maxTeilnehmer": 16,
          "harteGrenze": true
        }
      ],
