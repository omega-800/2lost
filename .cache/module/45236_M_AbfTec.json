  "kurse": [
    {
      "id": 45237,
      "kuerzel": "AbfTec",
      "bezeichnung": "Abfallwirtschaft und -technologien",
      "lernziele": "Siehe Modulbeschreibung",
      "planinhalt": "<ul>\n<li>Abf&auml;lle gestern und heute</li>\n<li>Grundlagen der Abfallwirtschaft Schweiz</li>\n<li>&Uuml;bersicht Abf&auml;lle und Vertiefung Siedlungsabf&auml;lle</li>\n<li>Thermische Behandlung von Siedlungsabf&auml;llen</li>\n<li>Thermische Abfallbehandlung: Abgasreinigung</li>\n<li>Bauabf&auml;lle und Ressourcenthematik</li>\n<li>Kl&auml;rschl&auml;mme und Wirbelschichttechnologie</li>\n<li>Sonderabf&auml;lle und Drehrohrtechnologie</li>\n<li>Biogene Abf&auml;lle und Verwertungstechnologien</li>\n<li>Energie und Metalle aus Abf&auml;llen</li>\n<li>Grundlagen stoffliche Verwertung von Abf&auml;llen</li>\n<li>Endlagerung</li>\n<li>Alternative Verfahren zur thermischen Abfallbehandlung</li>\n</ul>\n<p>&nbsp;</p>\n<p>Der Unterricht wird erg&auml;nzt mit</p>\n<ul>\n<li>Exkursionen zu Umwelttechnikbetrieben</li>\n<li>Referaten von Fachexperten</li>\n<li>Diskussionen aktueller Themen</li>\n</ul>\n<p>&nbsp;</p>\n<p>Die &Uuml;bungen finden auf Anlagen statt.</p>",
