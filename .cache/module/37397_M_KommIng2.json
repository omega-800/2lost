{
  "id": 37397,
  "kuerzel": "M_KommIng2",
  "bezeichnung": "Kommunikation 2 für IngenieurInnen  (Teamkommunikation)",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Projekte erfolgreich durchf&uuml;hren (m&uuml;ndlich und schriftlich)</li>\n    <li>Grundlagen der Teamarbeit kennen lernen (Wir als Team)</li>\n    <li>Individuelle Teamkompetenz optimieren (Ich im Team)</li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 37398,
      "kuerzel": "TKI",
      "bezeichnung": "Teamkommunikation für IngenieurInnen",
      "lernziele": "<p>Erfolgreiche Projekte:</p>\n<ul>\n    <li>Sie kennen die verschiedenen Prozessebenen in Projekten und k&ouml;nnen sie erfolgreich gestalten</li>\n</ul>\n<p>Grundlagen der Teamarbeit:</p>\n<ul>\n    <li>Sie sind f&auml;hig, Prozesse der Teambildung und Teamentwicklung zu erkennen und die Teamprozesse gemeinsam zu gestalten</li>\n</ul>\n<p>Individuelle Teamkompetenz:</p>\n<ul>\n    <li>Sie sind f&auml;hig, die Teamprozesse mit Ihrem pers&ouml;nlichen Verhalten aktiv zu gestalten.</li>\n</ul>\n<p>&nbsp;</p>",
      "planinhalt": "<p>Projektmanagementprozess</p>\n<ul>\n    <li>Projektumfeld (Stakeholder, Situationsanalyse, Ziele)</li>\n    <li>Professionelles Sitzungsmanagement (incl. Protokolle)</li>\n</ul>\n<p>Teamentwicklungsprozess</p>\n<ul>\n    <li>Teambildung</li>\n    <li>Teamphasen und Teamrollen</li>\n    <li>Teameffektivit&auml;t</li>\n    <li>Konflikmanagement: Verhandeln</li>\n</ul>\n<p>Produktentstehungsprozess</p>\n<ul>\n    <li>Argumentieren in Projektberichten f&uuml;r externe Auftraggeber</li>\n    <li>Argumentieren und pers&ouml;nliches Auftreten in Projektpr&auml;sentationen vor externem Auftraggeber</li>\n</ul>",
