  "kurse": [
    {
      "id": 24428,
      "kuerzel": "IK",
      "bezeichnung": "Interkulturelle Kommunikation ",
      "lernziele": "<ul>\n    <li>Sie entwickeln Sensibilit&auml;t f&uuml;r die Kulturbedingtheit der eigenen und fremden Komunikationsgewohnheiten</li>\n    <li>Sie verstehen die psychologische Dynamik interkultureller Kommunikationssituationen</li>\n    <li>Sie sind in der Lage, mit Personen aus anderen Kulturkreisen produktiv zusammen zu arbeiten</li>\n</ul>",
      "planinhalt": "<p>Entwicklung interkultureller Sensibilit&auml;t</p>\n<p>Reflexion eigener und fremder kultureller Werte und Normen und ihre Auswirkung auf die berufliche Zusammenarbeit&nbsp;</p>\n<p>Dynamik interkultureller Kommunikationssituationen:</p>\n<ul>\n    <li>Stereotypen und Vorurteilsbildung, Beurteilungsfehler, Kommunikations-, Verhandlungs- und Konfliktstile </li>\n    <li>Herausforderungen der internationalen Personalentsendung </li>\n    <li>Kennenlernen von Methoden zur Beschreibung von Kulturen, z.B. Kulturdimensionen, Kulturstandards, Kulturstile </li>\n</ul>\n<p>Erweiterung des eigenen Handlungsrepertoires</p>\n<p>Interkulturelle Kommunikationssituationen produktiv gestalten, z.B. im Rahmen von realit&auml;tsgerechten Rollenspielen bzw. innterhalb der Projektarbeit</p>",
      "kurselemente": [
        {
          "id": 24429,
          "art": "Seminar",
          "anzLektionen": 2,
          "maxTeilnehmer": 25,
          "harteGrenze": true
        }
      ],
      "uebersetzungen": [
        {
          "id": 3701,
          "bezeichnung": "Interkulturelle Kommunikation"
        },
        {
          "id": 3702,
          "bezeichnung": "Intercultural Communication"
        }
      ]
    },
    {
      "id": 24430,
      "kuerzel": "FK",
      "bezeichnung": "Führungskommunikation für IngenieurInnen",
      "lernziele": "<ul>\n    <li>Sie kennen die wichtigsten formalen F&uuml;hrungsgespr&auml;chsformen</li>\n    <li>Sie k&ouml;nnen diese Gespr&auml;che sowohl aus der F&uuml;hrungsrolle als auch aus der Mitarbeiterrolle produktiv gestalten</li>\n</ul>",
      "planinhalt": "<p>Formale Kommunikationssituationen in Organisationen kennen lernen</p>\n<ul>\n    <li>Formale Gespr&auml;chsformen in Organisationen, wie z.B. Einstellungsgespr&auml;che, Zielvereinbarungsgespr&auml;che, Leistungsr&uuml;ckmeldung, Jahresmitarbeitergespr&auml;che, Beurteilungsgespr&auml;che, R&uuml;ckkehrgespr&auml;che, Entlassungsgespr&auml;che, etc. </li>\n    <li>F&uuml;hrung als rollenbezogene Kommunikation </li>\n</ul>\n<p>Formale Gespr&auml;chssituation produktiv gestalten</p>\n<ul>\n    <li>Gespr&auml;chsleitf&auml;den f&uuml;r die einzelnen Situationen kennen und nutzen </li>\n    <li>In den einzelnen Situationen aktiv werden, z.B. in Form von realit&auml;tsgerechten Rollenspielen </li>\n</ul>\n<p>&nbsp;F&uuml;hrungskommunikation schriftlich</p>",
