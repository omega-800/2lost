  "kurse": [
    {
      "id": 18413,
      "kuerzel": "RPlg1",
      "bezeichnung": "Grundlagen Raumplanung 1",
      "lernziele": "<p>Grundkenntnisse der kommunalen Raumplanung in der Schweiz und deren Begriffe. <br />Kenntnisse der Ziele und Grunds&auml;tze, Planungspflichten und Aufgaben gem&auml;ss Raumplanungsgesetz. (RPG).<br />Grundkenntnisse der &ouml;ffentlichen Nutzungsvorschriften und deren Anwendung. <br />Die verbreitetsten Planungsinstrumente und deren interdisziplin&auml;re Anwendung.<br />Grundkenntnisse &uuml;ber Planungsabl&auml;ufe und Mitwirkungsprozesse. <br /></p>",
      "planinhalt": "<p>Der Beruf des Raumplaners/der Raumplanerin. <br />Abriss &uuml;ber die Geschichte der Raumplanung. <br />Die r&auml;umliche Entwicklung der Schweiz.<br />Einf&uuml;hrung in das RPG: Planungspflicht, Ziele und Grunds&auml;tze.<br />Die Organisation der Raumplanung: die Aufgaben auf den verschiedenen Planungsebenen..<br />Die kommunalen Planungsinstrumente. <br />Grundlagen der kommunalen Nutzungsplanung.<br />Planungsablauf und Mitwirkung. <br />Nutzungszonen: Eignungskriterien und Anforderungen. <br />Bauen ausserhalb der Bauzonen.<br /></p>",
