  "kreditpunkte": 4,
  "lernziele": "<p>Image Processing and Computer Vision 1 and Image Processing and Computer Vision 2 form together a one-year introductory sequence into modern digital image processing and computer vision</p>\n<p>&nbsp;</p>",
  "vorausgKenntnisse": "<p>Digital Image Processing 1 or similar</p><ul></ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
