{
  "id": 40969,
  "kuerzel": "M_ELTE1",
  "bezeichnung": "Elektrotechnik 1 (WING)",
  "kreditpunkte": 2,
  "lernziele": "<p>Das Modul ELTE1 vermittelt die wichtigsten Grundlagen und Zusammenh&auml;nge der Elektrotechnik in Theorie und Praxis f&uuml;r das Verst&auml;ndnis und die Beurteilung von diesbez&uuml;glichen Sachverhalten und f&uuml;r den Austausch mit Fachleuten. Das Modul f&ouml;rdert systemisches Denken, bef&auml;higt zum Transfer in neue Anwendungsgebiete.</p>",
  "vorausgKenntnisse": "<p>Grundkenntnisse in Physik und Mathematik&nbsp;</p>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 40970,
      "kuerzel": "ELTECH1W",
      "bezeichnung": "Elektrotechnik 1 (WING)",
      "lernziele": "<p><strong>Fachkompetenzen</strong></p>\n<ul>\n<li>Grundlagen Elektrotechnik, Stromkreislauf, Kirchhoff'sche Gesetze</li>\n<li>elektrische Schaltungen in Serie - Parallel - Gemischt</li>\n<li>Reale Spannungsquellen, Kennlinien, Arbeitspunkte</li>\n<li>Leistung, Energie, Umwandlungen, Wirkungsgrad</li>\n<li>Sicherheit. Personenschutz in der Elektrotechnik</li>\n<li>Angewandte elektronische Schaltungen, Peripherie</li>\n<li>Mikrocontroller mit Sensor-, Aktor- Anwendungen</li>\n<li>Realisierung einer Elektrotechnik-/Elektronikanwendung</li>\n</ul>\n<p><br /><strong>Methodenkompetenzen</strong></p>\n<ul>\n<li>Realisierung elektrischer / elektronischer Schaltungen</li>\n<li>Bedeutung elektrischer Energie mit Versorgung erl&auml;utern</li>\n<li>Energieaufwand und Optimierungen aufzeigen</li>\n<li>Elektrische Messmittel korrekt anwenden</li>\n<li>Sicherer Umgang mit Elektrizit&auml;t und el. Betriebsmitteln</li>\n<li>Methoden der AD-Wandlung und PWM erl&auml;utern</li>\n</ul>\n<p><br /><strong>Selbstkompetenzen</strong></p>\n<ul>\n<li>Regeln des Personenschutzes umsetzen</li>\n<li>Gefahrensituationen erkennen und Massnahmen ergreifen</li>\n<li>Schaltung im Team entwerfen, aufbauen, Testen, pr&auml;sentieren</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Sozialkompetenzen</strong></p>\n<ul>\n<li>Teamarbeit f&uuml;r Schaltungsentwicklung</li>\n<li>Korrektes Verhalten bez&uuml;glich elektrischer Gefahren</li>\n<li>Zielf&uuml;hrende Diskussionen leiten, korrektes Argumentieren in Elektrotechnikthemen</li>\n</ul>",
      "planinhalt": "<p><strong>Grundlagen der Elektrotechnik</strong></p>\n<ul>\n<li>Stromkreise in Serie parallel und gemischt berechnen, aufbauen, ausmessen</li>\n<li>Funktionsweise elektrischer Messmittel, korrekte Anwendung</li>\n<li>Reale Strom- und Spannungsquellen, elektrische Leistung, Energie, Umwandlungen, Wirkungsgrad</li>\n<li>Berechnungen zu Energieaufwand und Kosten ausf&uuml;hren, Aufzeigen von Optimierungen</li>\n<li>Sicherer Umgang mit Elektrizit&auml;t und el. Betriebsmitteln, Gef&auml;hrdung von Personen und Sachen vermeiden</li>\n<li>Angewandte elektronische Schaltungen, Peripherie, Mikrocontroller mit Sensor-, Aktor- Anwendungen</li>\n<li>L&auml;ngspraktikum: Realisierung einer Elektrotechnik-/Elektronikanwendung entlang des Unterrichts</li>\n</ul>",
      "bibliographie": "<p>&nbsp;</p>\n<p>&nbsp;</p>",
