    {
      "id": 16412,
      "kuerzel": "SiedSo1",
      "bezeichnung": "Siedlungssoziologie 1",
      "lernziele": "<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: &quot;Arial&quot;,&quot;sans-serif&quot;\">Verstehen der wechselseitigen Beziehungen zwischen sozialen und r&auml;umlichen Organisation der Gesellschaft. Erkennen der Wirkungen und Wirkungsweise des sozialen Wandels auf den Raum und auf die Siedlungsstruktur.\n<p>&nbsp;</p>\n</span></p>",
      "planinhalt": "<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Siedlungssoziologie und ihre Bedeutung f&uuml;r die Raumplanung</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Grundbegriffe und Schl&uuml;sselkonzepte der Siedlungssoziologie</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">St&auml;dte und Stadtplanung in Vergangenheit</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">St&auml;dte und Stadtplanung in Gegenwart</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">St&auml;dte und Stadtplanung in Zukunft</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Sozial&ouml;kologie, Stadtmodelle, Segregation</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Ausschl&uuml;sse, Beteiligung, Integration und gesellschaftlicher Zusammenhalt</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Neue Informations- und Kommunikationstechnologien (IKT)</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Nachhaltigkeit und soziale Nachhaltigkeitsdimension</span></p>\n<p class=\"MsoNormal\" style=\"MARGIN: 0cm 0cm 0pt; LINE-HEIGHT: normal\"><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \"></span><span style=\"FONT-SIZE: 10pt; FONT-FAMILY: \">Aktuelle Trends der Bev&ouml;lkerungsentwicklung in urbanen Regionen</span></p>",
