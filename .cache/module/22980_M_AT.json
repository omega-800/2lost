{
  "id": 22980,
  "kuerzel": "M_AT",
  "bezeichnung": "Antriebstechnik",
  "kreditpunkte": 4,
  "lernziele": "<p>F&auml;higkeit zur Auslegung geeigneter elektrischer, pneumatischer und hydraulischer&nbsp;Antriebssysteme erwerben<br /></p>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 22981,
      "kuerzel": "FluAn",
      "bezeichnung": "Fluidisch",
      "lernziele": "<p class=\"MsoNormal\" style=\"margin: 0cm 3.15pt 0pt 0cm;\">Basiswissen &uuml;ber fluidische Antriebe reflektiert.</p>\n<p class=\"MsoNormal\" style=\"margin: 0cm 3.15pt 0pt 0cm;\">Den gebr&auml;uchlichen Aufbau fluidischer Antriebe und deren Ansteuerung kennen.</p>\n<p class=\"MsoNormal\" style=\"margin: 0cm 3.15pt 0pt 0cm;\">Typische Elemente fluidischer Antriebsysteme benennen und erkl&auml;ren k&ouml;nnen.</p>\n<p class=\"MsoNormal\" style=\"margin: 0cm 3.15pt 0pt 0cm;\">Grunds&auml;tzliche Antriebsysteme entwerfen und dimensionieren k&ouml;nnen.</p>",
      "planinhalt": "<p>&Uuml;berblick &uuml;ber den Aufbau und die Arbeitsweise fluidischer Antriebe.<br />Auslegung der gesamten fluidischen Antriebsl&ouml;sung inkl. Energieversorgung.</p>\n<p>Pneumatik: <br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Grundlagen Schaltplanaufbau und Komponenten repetieren<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Aufbau und Eigenschaften pneumatischer Antriebskomponenten unterscheiden<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Auslegung, Dimensionierung und Projektierung pneumatischer Anlagen vornehmen<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Praktikum A zur Vertiefung und Festigung des Lerninhalts Pneumatik<br />Elektropneumatik<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Grundlagen Schaltplanaufbau und Komponenten repetieren<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Praktikum B zur Vertiefung und Festigung des Lerninhalts Elektropneumatik<br />Hydraulik<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Grundlagen Schaltplanaufbau und Komponenten repetieren<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Aufbau und Eigenschaften hydraulischer Antriebskomponenten unterscheiden<br />&bull;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Auslegung, Dimensionierung und Projektierung hydraulischer Anlagen vornehmen</p>",
