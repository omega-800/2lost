    {
      "id": 55924,
      "kuerzel": "boek.ITA2",
      "bezeichnung": "Italienisch 2",
      "kreditpunkte": 0,
      "lernziele": "<p><strong>Fachkompetenzen:</strong></p>\n<ul>\n<li>Kenntnis der wichtigsten grammatikalischen Strukturen</li>\n<li>Beherrschen des Alltags-Wortschatzes</li>\n<li>Ein&uuml;ben der italienischen Modulation und Satzmelodie</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Methodenkompetenzen:</strong></p>\n<ul>\n<li>Eigenst&auml;ndiges Fragestellen in Alltags-Situationen</li>\n<li>Selbst&auml;ndiges, adressengerechtes Reagieren im Kontext</li>\n<li>Erfassen von einfachen Zeitungsmeldungen</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Sozialkompetenzen:</strong></p>\n<ul>\n<li>Sich situationskonform mit Personen verschiedenster Herkunft unterhalten</li>\n<li>Sich in die italienische Mentalit&auml;t und Lebensweise einf&uuml;hlen k&ouml;nnen</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Selbstkompetenzen:</strong></p>\n<ul>\n<li>Grammatikalische und lexikalische Kenntnisse selbst&auml;ndig und<br />outputorientiert verarbeiten</li>\n<li>Sicherheit im Umgang mit Personen italienischer Muttersprache</li>\n<li>Autonome Bewertung der landeskundlichen Kultur</li>\n</ul>",
      "planinhalt": "<p><strong>Themen-/Lernblock I</strong></p>\n<p>&Uuml;ber sich reden</p>\n<p><strong>Themen-/Lernblock II</strong></p>\n<p>Italien entdecken, &uuml;ber Reisen reden</p>\n<p><strong>Themen-/Lernblock III</strong></p>\n<p>&Uuml;ber die Familie und die Traditionen reden<strong><br></strong></p>\n<p><strong>Themen-/Lernblock IV<br></strong>Einkaufen in Gesch&auml;ften und auf dem Markt</p>\n<p><strong>Themen-/Lernblock V<br></strong>&Uuml;ber die Arbeit und die Gesundheit reden. Pr&uuml;fungsvorbereitung</p>\n<p><br><br></p>",
      "bibliographie": "<p>&bdquo;DIECI\" LEZIONI DI ITALIANO<br>Ein Italienischkurs - Kurs-und Arbeitsbuch A1<br>Hueber Verlag, M&uuml;nchen 2021<br>ISBN 978-3-19-005647-7<br>Lezioni 6 - 10</p>",
      "empfLehrmittel": "<p>Lehrgespr&auml;ch, Einzelarbeit, Partnerarbeit, Gruppenarbeit, angeleitetes<br>Selbststudium, Selbststudium</p>",
