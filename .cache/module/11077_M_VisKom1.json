{
  "id": 11077,
  "kuerzel": "M_VisKom1",
  "bezeichnung": "Visuelle Kommunikation 1",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Vermittlung der Methoden f&uuml;r die Darstellung und Kommunikation von Projekten</li>\n    <li>Sensibilisierung der r&auml;umlichen Wahrnehmung</li>\n    <li>Erarbeitung kreativer Darstellungsm&ouml;glichkeiten f&uuml;r Entwurf und Planung</li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 10195,
      "kuerzel": "Typo1",
      "bezeichnung": "Typografie-Layout-Farbe-1",
      "lernziele": "<ul>\n    <li>Aneignen von Schriftkenntnissen</li>\n    <li>Basisfachwissen Typografie</li>\n    <li>Grundkenntnisse in der zweidimensionalen Darstellung</li>\n</ul>",
      "planinhalt": "<p>Bewusstes Zusammenbringen von Texten und Schriften; Einf&uuml;hrung in die grafische Darstellung von Daten oder Informationen (Diagramme); Einf&uuml;hrung in die Generalisierung und Abstraktion von thematischen Pl&auml;nen; Verwendung von Schrift, Symbolen und&nbsp; Farben in Pl&auml;nen; Projektbezogene Anwendungen f&uuml;r den Entwurfs- und Planungsunterricht; Digitale Techniken: Einf&uuml;hrung in g&auml;ngige Layoutprogramme (z.B. InDesign).</p>\n<p>4 Lektionen alle 2 Wochen.</p>",
      "kurselemente": [
        {
          "id": 12376,
          "art": "Praktikum",
          "anzLektionen": 2,
          "maxTeilnehmer": 18,
          "harteGrenze": true
        }
      ],
