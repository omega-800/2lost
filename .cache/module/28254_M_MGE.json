{
  "id": 28254,
  "kuerzel": "M_MGE",
  "bezeichnung": "Mobile and GUI Engineering",
  "kreditpunkte": 4,
  "lernziele": "<p>Die Studierenden k&ouml;nnen:</p>\n<ul>\n<li>Grundkonzepte von Android und .NET MAUI anwenden und erkl&auml;ren</li>\n<li>Fortgeschrittene Android- und .NET MAUI-Themen erl&auml;utern</li>\n<li>&Uuml;bergreifende GUI-Themen anwenden und erkl&auml;ren (Architektur, Design Patterns, Best Practices, etc.)</li>\n</ul>",
  "vorausgKenntnisse": "<ul>\n<li>Grundlagen zu objektorientierter Programmierung (z.B. durch OOP1, OOP2 und AlgDat)</li>\n<li>Grundlagen zu relationalen Datenbank (z.B. durch Dbs1)</li>\n<li>Grundlagen zur Verwendung von Git (z.B. durch SEP1)</li>\n<li>Grundkenntnisse von .NET / C# (Paralleler Besuch von MsTe empfohlen!)</li>\n<li>Englisch</li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 28255,
      "kuerzel": "MGE",
      "bezeichnung": "Mobile and GUI Engineering",
      "planinhalt": "<p>Teil 1: Mobile Apps mit Android</p>\n<ul>\n<li>Relevanz der App Entwicklung</li>\n<li>Grundlagen zum Betriebssystem</li>\n<li>Entwicklung von Android-Apps</li>\n<li>Erstellung einer eigenen App als Miniprojekt (Testat)</li>\n</ul>\n<p>&nbsp;</p>\n<p>Teil 2: Cross-Plattform Applikationen mit .NET MAUI</p>\n<ul>\n<li>Grundlagen zu .NET und C#</li>\n<li>Entwicklung von .NET MAUI-Applikationen</li>\n<li>Verwendung von .NET MAUI f&uuml;r Desktop und Mobile</li>\n<li>Ausblick: Weitere XAML-basierte UI-Frameworks in .NET (WPF, Xamarin, ...)</li>\n</ul>\n<p>&nbsp;</p>\n<p>&Uuml;bergreifende Themen</p>\n<ul>\n<li>Musterarchitekturen in GUI-Applikationen</li>\n<li>Design Patterns der GUI-Entwicklung (Observer, MVC, MVP und MVVM)</li>\n<li>Dependency Inversion Principle (DIP)</li>\n<li>Trennung von Darstellung und Logik</li>\n<li>Main- und Background-Threads</li>\n<li>Designsprachen und Guidelines</li>\n</ul>",
