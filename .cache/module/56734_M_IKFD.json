{
  "id": 56734,
  "kuerzel": "M_IKFD",
  "bezeichnung": "Applied Frugal Design: Einfach gestalten, gesund leben",
  "kreditpunkte": 2,
  "lernziele": "<p>Kreative Probleml&ouml;sungsf&auml;higkeiten sind essenziell, um die Herausforderungen einer zunehmend komplexen Welt zu meistern. Laut WEF z&auml;hlt diese F&auml;higkeit zu den wichtigsten Zukunftskompetenzen des 21. Jahrhunderts. &laquo;Frugales Design&raquo; beschreibt, wie mit minimalem Ressourceneinsatz eine grosse Wirkung erzielt werden kann. Dieses Modul bef&auml;higt Studierende unterschiedlicher Disziplinen, f&uuml;r konkrete Alltagsprobleme aus dem Gesundheitswesen oder aus der Rehabilitation selbst&auml;ndig und kreativ praktische Hilfsmittel zur Erleichterung des Alltags zu entwickeln und herzustellen.&nbsp;</p>",
  "semesterBewertung": "bestanden / nicht bestanden",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 56735,
      "kuerzel": "IKFD",
      "bezeichnung": "Applied Frugal Design: Einfach gestalten, gesund leben",
      "kreditpunkte": 2,
      "lernziele": "<p><strong>Sachkompetenzen</strong></p>\n<p><em>Die Studierenden k&ouml;nnen:</em></p>\n<ul>\n<li>Anwendung des Design Thinking-Ansatzes</li>\n<li>Anwendung des Frugal Design-Ansatzes</li>\n<li>Anwendung unterschiedlicher Prototyping-Methoden und -Werkzeuge (z.B. 3D-Prototyping, UI-Tools, CAD oder TinkerKits)</li>\n<li>Kenntnis der grundlegenden Prinzipien des mensch-zentrierten Product Designs</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Selbstkompetenzen</strong></p>\n<p><em>Die Studierenden k&ouml;nnen:</em></p>\n<ul>\n<li>St&auml;rkung des Kreativit&auml;tspotentials</li>\n<li>St&auml;rkung der Probleml&ouml;sungskompetenz</li>\n<li>St&auml;rkung der Creative Confidence</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Sozialkompetenzen</strong></p>\n<p><em>Die Studierenden k&ouml;nnen:</em></p>\n<ul>\n<li>St&auml;rkung der interdisziplin&auml;ren Kollaborationsf&auml;higkeit</li>\n<li>St&auml;rkung der mehrperspektivischen Nutzendenbetrachtung</li>\n<li>St&auml;rkung des inklusiven Denkens&nbsp;</li>\n</ul>",
      "planinhalt": "<p><strong>Lernblock I</strong></p>\n<p><em>Design, Komplexit&auml;t &amp; Einschr&auml;nkungen</em></p>\n<ul>\n<li>Einf&uuml;hrung in Applied Frugal Design</li>\n<li>Kreativit&auml;tsf&ouml;rderung &amp; -methoden</li>\n<li>Problem Framing</li>\n<li>Frugale Innovation (Sufficing), Design Thinking</li>\n<li>Unternehmensbesuch bei Industrial-Design-Firma</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Lernblock II</strong></p>\n<p><em>Universalit&auml;t, Kreativit&auml;t &amp; Anwendung </em></p>\n<ul>\n<li>Anwendungs-Fall</li>\n<li>Design for Accessibility &amp; Universal Design als Inspiration zur Frugalen Innovation &nbsp;</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Lernblock III</strong></p>\n<p><em>Prototyping, Testing &amp; Iterating</em></p>\n<ul>\n<li>Frugale Prototyping-Werkzeuge &amp; -Methoden (Papier, Pappe, Holz, Modelliermassen, 3D-Druck, Software zur User-Interface-Gestaltung von Apps, etc.)</li>\n<li>User Testing &amp; Iteration</li>\n</ul>\n<p>&nbsp;</p>\n<p><strong>Lernblock IV</strong></p>\n<p><em>Reflektion und Pr&auml;sentation</em></p>\n<ul>\n<li>Review der Vorgehensweise</li>\n<li>Lessons Learned</li>\n<li>Ergebnispr&auml;sentation&nbsp;</li>\n</ul>",
      "empfLehrmittel": "<p>Einzel- und Gruppenarbeiten, Theorie-Lehrgespr&auml;che, individuelles Coaching, Diskussionen im Plenum, Projektarbeit&nbsp;</p>",
      "leistungsnachweis": "<p>&nbsp;Aktive Pr&auml;senz, Auftragsbearbeitung, Projektpr&auml;sentation.&nbsp;</p>",
