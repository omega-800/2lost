  "kreditpunkte": 4,
  "lernziele": "<span lang=\"DE\" new=\"\">\n<p><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">Die Wirtschaft ist der mit Abstand gr&ouml;sste Anwendungsbereich der Informatik. Das Modul Wirtschaftsinformatik 1 erschliesst dieses Gebiet systematisch.</span></p>\n<p><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">Die Studierenden</span></p>\n<ul>\n    <li><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">&uuml;berschauen die f&uuml;r Informations- und Kommunikationstechnologien (ICT) relevanten betriebswirtschaftlichen Grundlagen und Organisationskonzepte.</span> </li>\n    <li><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">verstehen wirtschaftliche Mechanismen und Zielsetzungen.</span> </li>\n    <li><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">erkennen erfolgreiche ICT-Strategien im Wirtschaftsgeschehen.</span> </li>\n    <li><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">kennen geeignete Anwendungssysteme f&uuml;r betriebliche Aufgabenstellungen.</span> </li>\n    <li><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">erkennen das Potenzial von ICT im Zusammenspiel mit Menschen und Organisation.</span> </li>\n    <li><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">beurteilen Fallstudien und wirtschaftliche Problemstellungen aus der ICT-Perspektive.<br /></span></li>\n</ul>\n<p><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\">Lehrmittel: Buch, Pr&auml;sentationen, Fallstudien, Videos, &Uuml;bungen<br />&bull;&nbsp;Interaktive Lernumgebung<br />&bull;&nbsp;Selbsttests zur eigenen Standortbestimmung<br />&bull;&nbsp;Alle Lehrmittel werden digital bereit gestellt<br />&bull;&nbsp;Ein aktuelles Gastreferat wird angestrebt<br />&bull;&nbsp;Bitte bringen Sie Ihr Notebook / Tablet in den Unterricht</span><span style=\"FONT-FAMILY: \" lang=\"DE\" new=\"\"><br /></span></p>\n</span>",
  "vorausgKenntnisse": "<p>Englischkenntnisse</p>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
