{
  "id": 45704,
  "kuerzel": "M_ProdMan",
  "bezeichnung": "Produktionsmanagement",
  "kreditpunkte": 4,
  "lernziele": "<ul>\n    <li>Die Rollen der Entwicklung, der Produktion und der Beschaffung in den beiden Gesch&auml;ftsprozessen&nbsp; Serien- und Anlagenbau verstehen.</li>\n    <li>Als Entwicklungsverantwortlicher die Teilaufgaben von Produktion und Beschaffung so kennen, dass im Entwicklungsprozess und &ndash;projekt diese Funktionen optimal integriert werden k&ouml;nnen.</li>\n    <li>Die in den beiden Gesch&auml;ftsprozessen typischen Treiber und Risiken f&uuml;r Herstellkosten, Liefer- /Abnahmef&auml;higkeit und Kapitalbedarf identifizieren und steuern k&ouml;nnen. </li>\n    <li>Die Wechselwirkungen von Produktstruktur, Seriegr&ouml;sse, Fertigungsverfahren und Werkstoffwahl auf die Herstellkosten, Lieferf&auml;higkeit und den Kapitalbedarf&nbsp; gezielt beeinflussen k&ouml;nnen.<br /></li>\n</ul>",
  "semesterBewertung": "Note von 1 - 6",
  "sprache": "de-CH",
  "zustand": "deaktiviert",
  "kurse": [
    {
      "id": 45705,
      "kuerzel": "ProdMan",
      "bezeichnung": "Produktionsmanagement",
      "lernziele": "siehe Lernziele des Moduls",
      "planinhalt": "<ul>\n    <li>Unterschiede und Gemeinsamkeiten im Gesch&auml;ft und Prozessmodell von Serien- und Anlagenbauern </li>\n    <li>Kostenrechnung, Kalkulation und Wirtschaftlichkeitsrechnung </li>\n    <li>Arbeitsplanung </li>\n    <li>Produktionsplanung </li>\n    <li>Beschaffung, Make or Buy </li>\n    <li>Fertigung und Fertigungssteuerung, Grundlagen der Lean Production </li>\n    <li>F&uuml;hrungsmittel in Beschaffung und Produktion </li>\n    <li>Der Leiter Produktion und Beschaffung im Serienbau, SPC </li>\n    <li>Der Leiter Produktion und Beschaffung im Anlagenbau </li>\n</ul>",
