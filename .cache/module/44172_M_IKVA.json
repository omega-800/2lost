{
  "id": 44172,
  "kuerzel": "M_IKVA",
  "bezeichnung": "Virtual Reality für gesundes Leben und Altern",
  "kreditpunkte": 2,
  "lernziele": "<p>Leitidee:</p>\n<p>Virtual Reality f&uuml;r gesundes Leben und Altern Mit g&uuml;nstiger stand-alone Hardware wird Virtual Reality zu einem praktischen Werkzeug, um immersiv Einblicke und Erlebnisse zu erm&ouml;glichen die sonst in der Realit&auml;t zu aufwendig, zu teuer oder zu gef&auml;hrlich w&auml;ren. In Verbindung mit Themen zum gesunden Leben und Altern ist es das Ziel, das notwendige Wissen und Handwerk zu VR &uuml;ber die Technik-Studieng&auml;nge hinaus allen Studierenden zug&auml;nglich zu machen.</p>",
  "semesterBewertung": "bestanden / nicht bestanden",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 44173,
      "kuerzel": "IKVA",
      "bezeichnung": "Virtual Reality für gesundes Leben und Altern",
      "kreditpunkte": 0,
      "lernziele": "<p>Sachkompetenzen&nbsp;<br />Die Studierenden k&ouml;nnen: &nbsp;</p>\n<ul>\n<li>Anzeichen, Verlauf und Auswirkung von Demenz benennen.</li>\n<li>soziale Auswirkungen des Alterns und vorbeugende Massnahmen erkl&auml;ren.</li>\n<li>mit Unreal Engine selbst VR-Umgebungen erzeugen und auf VR-Headsets einsetzen.</li>\n<li>eigenen 3D Objekte und deren Funktionen erstellen.</li>\n<li>erkl&auml;ren, welche sozialen und gesundheitlichen Herausforderungen im Alter auftreten k&ouml;nnen.</li>\n</ul>\n<p>&nbsp;</p>\n<p>Selbstkompetenzen&nbsp;<br />Die Studierenden k&ouml;nnen: &nbsp;</p>\n<ul>\n<li>den eigenen Lebenswandel im Hinblick auf gesundes Verhalten &uuml;berpr&uuml;fen.</li>\n<li>reflektieren, welchen Einfluss Altern auf den Lebensverlauf haben kann.</li>\n<li>eigenen Ideen in der virtuellen Welt realisieren.</li>\n</ul>\n<p>&nbsp;</p>\n<p>Sozialkompetenzen&nbsp;<br />Die Studierenden k&ouml;nnen:&nbsp;</p>\n<ul>\n<li>gesundes Leben und Altern bei sich und anderen unterst&uuml;tzen.</li>\n<li>der sozialen Ausgliederung in Ihrem Umfeld und sp&auml;teren Beruf entgegenwirken.</li>\n<li>in einer Gruppe L&ouml;sungen der VR Realisation pr&auml;sentieren.</li>\n</ul>",
      "planinhalt": "<p>Lernblock I&nbsp;<br />Bereich Gesundheit&nbsp;</p>\n<ul>\n<li>Lebensqualit&auml;t durch gesundes Essen, Bewegung und Lebensgewohnheiten&nbsp;</li>\n<li>Leben mit Demenz f&uuml;r Betroffene, Angeh&ouml;rige und Betreuer&nbsp;</li>\n<li>Leben mit der Alterung &ndash; Ver&auml;nderung von Gewohnheiten und Hilfsmittel&nbsp;</li>\n</ul>\n<p><br />Lernblock II&nbsp;<br />Bereich Soziale Arbeit&nbsp;</p>\n<ul>\n<li>Einsamkeit und soziale Vernachl&auml;ssigung im Alter&nbsp;</li>\n<li>das Generationenhaus als integriertes Wohnen im Alter&nbsp;</li>\n<li>Strukturen zur Steigerung der Lebensqualit&auml;t im Alter&nbsp;</li>\n</ul>\n<p><br />Lernblock III&nbsp;<br />Bereich Virtual Reality&nbsp;</p>\n<ul>\n<li>Aufsetzen der notwendigen Entwicklungsumgebung mit Unreal Engine&nbsp;</li>\n<li>Erstellen von eigenen Umgebungen aus vorhandenen 3D Bibliotheken&nbsp;</li>\n<li>Implementieren von Interaktionen mit der 3D Umgebung&nbsp;</li>\n<li>Erstellen von eigenen 3D Modellen mit Blender und Unreal Engine</li>\n</ul>",
      "bibliographie": "",
      "empfLehrmittel": "<p>Kontaktunterricht und begleitete &Uuml;bungen, Hausaufgaben&nbsp;</p>",
      "bemerkungKurs": "",
      "leistungsnachweis": "<p>Erstellung einer eigenen VR-Applikation zur Vermittlung von Themen aus gesundem Leben und Altern&nbsp;</p>",
