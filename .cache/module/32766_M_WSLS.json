  "bezeichnung": "Workshop \"Lern-Support an der OST\"",
  "kreditpunkte": 0,
  "lernziele": "<p>Teil 1: Pers&ouml;nliche Lernplanung<br />Teil 2: Lerntechnik<br />Teil 3: Individuelles Lerncoaching</p>",
  "semesterBewertung": "besucht / nicht besucht",
