{
  "id": 45191,
  "kuerzel": "M_TFD2EU",
  "bezeichnung": "Thermo- und Fluiddynamik 2 (EEU)",
  "kreditpunkte": 4,
  "lernziele": "<p><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">&nbsp;Die Studierenden &hellip; </span></span></p>\n<ul>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">k&ouml;nnen die Thermodynamik und Fluiddynamik auf konkrete Anlagen wie W&auml;rmepumpen, K&auml;ltemaschinen, unterschiedliche von thermischen Kraftwerken, L&uuml;ftungsanlagen und hydraulischen Anlagen anwenden.</span></span></span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">k&ouml;nnen Pumpen und Gebl&auml;se auslegen und kennen Ursachen von und Ma&szlig;nahmen gegen Kavitation.</span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">praktische Problemstellungen mit feuchter Luft analysieren und quantitativ beantworten.</span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">k&ouml;nnen selbstst&auml;ndig Messungen an realen Anlagen durchf&uuml;hren, die Messergebnisse analysieren und interpretieren.</span></span></li>\n</ul>",
  "semesterBewertung": "keine Note oder Wertung",
  "sprache": "de-CH",
  "zustand": "aktiviert",
  "kurse": [
    {
      "id": 45192,
      "kuerzel": "TFD2EU",
      "bezeichnung": "Thermo- und Fluiddynamik 2",
      "lernziele": "<p><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">Siehe Modulbeschreibung (Das ist die Kursbeschreibung, die Modulbeschreibung ist weiter oben).</span></span></p>",
      "planinhalt": "<ul>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">Station&auml;re Drossel, kompressibel und inkompressibel</span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">W&auml;rmepumpen und K&auml;ltemaschinen</span></span></span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">Thermische Kraftwerke: Gasturbinenprozess, Dampfprozess, Kombiprozess, ORC-Anlagen</span></span></span></span></span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">Arbeits- und Kraftmaschinen, Gebl&auml;se, Pumpen und Leitungssysteme</span></span></span></span></span></span></span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">Gas-Dampf-Gemisch: Feuchte Luft, Zustandsbeschreibung und Zustands&auml;nderungen.</span></span></span></span></span></span></span></span></span></span></li>\n<li><span style=\"vertical-align: inherit;\"><span style=\"vertical-align: inherit;\">Praktikum mit 1 Semesterwochenstunde in Bl&ouml;cken</span></span></li>\n</ul>",
