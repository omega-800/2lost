  "kurse": [
    {
      "id": 31877,
      "kuerzel": "FEM2",
      "bezeichnung": "Finite Elemente Methode 2 ",
      "lernziele": "<p>Fachkompetenzen:</p>\n<p>Konzepte und Theorien (gepr&uuml;ft) / Verfahren und Technologien (gepr&uuml;ft)</p>\n<p>&nbsp;</p>\n<p>Methodenkompetenzen:</p>\n<p>Analytische Kompetenzen (gepr&uuml;ft) / Entscheidungsfindung (gepr&uuml;ft) / Medien und digitale Technologien (gepr&uuml;ft) / Probleml&ouml;sung (gepr&uuml;ft) / Projektmanagement (gepr&uuml;ft)</p>\n<p>&nbsp;</p>\n<p>Selbstkompetenzen:</p>\n<p>Anpassung und Flexlibilit&auml;t (gepr&uuml;ft) / Kreatives Denken (gepr&uuml;ft) / Kritisches Denken (gepr&uuml;ft) / Integrit&auml;t und Arbeitsethik (gepr&uuml;ft) / Selbsbewusstsein und Selbstreflexion (gepr&uuml;ft) / Selbststeuerung und Selbstmanagement (nicht gepr&uuml;ft)</p>\n<p>&nbsp;</p>\n<p>Sozialkompetenzen:</p>\n<p>Kommunikation (nicht gepr&uuml;ft) / Kooperation und Teamarbeit (gepr&uuml;ft) / Kundenorientierung (gepr&uuml;ft) / Menschenf&uuml;hrung und Verantwortung (nicht gepr&uuml;ft) / Selbstdarstellung und soziale Einflussnahme (nicht gepr&uuml;ft) / Sensibilit&auml;t f&uuml;r Vielfalt (nicht gepr&uuml;ft)</p>",
      "planinhalt": "<ul>\n<li>Herleitung der Finite Elemente Methode auf Basis des Variationsprinzips</li>\n<li>Erl&auml;uterung der Elementansatzfunktionen und deren Einfluss auf die Rechengenauigkeit</li>\n<li>Herleitung der Element- und Gesamtsteifigkeitsmatrix</li>\n<li>Anwendung der FEM zur L&ouml;sung und Optimierung anwendungsnaher dynamischer und thermischer Problemstellungen</li>\n<li>&Uuml;bungen mit Verfassung technischer Berichte zu Problemstellungen u.a. aus der Strukturdynamik und thermisch-transienter Lastf&auml;lle</li>\n</ul>",
      "bibliographie": "<p>Unterrichtsunterlagen in Form von Slides, Anleitungen und Videotutorials stehen zur Verf&uuml;gung&nbsp;</p>\n<p>&nbsp;</p>\n<p>weiterf&uuml;hrende Literatur:</p>\n<p>Klein, B.: Grundlagen und Anwendungen der Finite-Elemente-Methode im Maschinen- und Fahrzeigbau; &nbsp;Springer Verlag / Deger, Y.: Die Methode der Finiten Elemente, Expert Verlag</p>",
