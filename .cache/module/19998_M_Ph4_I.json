  "kreditpunkte": 4,
  "lernziele": "<ul> <li>Kentnisse der zeitabh&#228;ngigen Vorg&#228;nge in Natur und Technik: Schwingungen und Wellen.</li><li>Kenntnisse der elektrischen und magnetischen Ph&#228;nomene. <br /><br /><br /></li></ul>",
  "vorausgKenntnisse": "<p>&nbsp;</p>\n<p>&nbsp;</p>",
