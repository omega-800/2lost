  "kurse": [
    {
      "id": 19999,
      "kuerzel": "Ph4_I",
      "bezeichnung": "Elektrizitätslehre für Informatiker",
      "lernziele": "<ul> <li>Verst&#228;ndnis von Wellenph&#228;nomenen in Netzwerken.</li><li>Verst&#228;ndnis von elektrodynamischen Vorg&#228;ngen im Umfeld der Informatik.</li></ul>",
      "planinhalt": "<ol>\n    <li><strong>Schwingung:</strong> Harmonische, unged&auml;mpft und ged&auml;mpft Schwingungen; Begriff des Spektrums;&nbsp;Erzwungene Schwingungen und Resonanz. </li>\n    <li><strong>Wellen:</strong>&nbsp;mathematische Beschreibung, Welleneigenschaften (Wellenl&auml;nge, Frequenz etc.); Interferenzen; Reflexion, Brechung und Transmission von Wellen, D&auml;mpfung; Elektromagnetische Wellen: Doppelleiter, Koaxialkabel, Impedanzen; </li>\n    <li><strong>Geometrische Optik:</strong> Lichwellenleiter, optische Daten&uuml;bertragung; </li>\n    <li><strong>Elektrisches Feld:</strong> Entstehung des E-Feldes, Energie und Energiedichte des E-Feldes, elektrische Spannung und Potential, <br />Feld und Potentialberechnungen f&uuml;r einfache Geometrien;&nbsp;Kondensator und seine Schaltungen. </li>\n    <li><strong>Elektrischer Strom:</strong> Transportmechanismen in Halbleitern, Metallen und Elektrolyten, Ohmsches Gesetz und Schaltungen <br />von Widerst&auml;nden, RC-Kreise, Joulsche W&auml;rme. </li>\n    <li><strong>Magnetostatik:</strong> Begriff des Magnetfeldes, Energiedichte des Magnetfeldes, Entstehung von B-Feldern und magnetische <br />Kr&auml;fte. </li>\n</ol>",
