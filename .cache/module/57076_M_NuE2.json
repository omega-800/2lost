    {
      "id": 57077,
      "kuerzel": "NuE2_N",
      "bezeichnung": "Nachhaltige Produktentwicklung",
      "kreditpunkte": 0,
      "lernziele": "<p>&nbsp;Die Studierenden</p>\n<ul>\n<li>kennen die grundlegenden R-Prinzipien und Ihre Auswirkung.</li>\n<li>kennen die rechtlichen Vorgaben f&uuml;r eine nachhaltige Produktentwicklung.</li>\n<li>kennen die Stellschrauben f&uuml;r nachhaltige Produktentwicklung.</li>\n<li>k&ouml;nnen einfache Lebenszyklusabsch&auml;tzungen durchf&uuml;hren.&nbsp;</li>\n</ul>",
      "planinhalt": "<ul>\n<li>Grundlagen Kreislaufwirtschaft (Definitionen, gesetz. Anforderungen, Konzepte)&nbsp;</li>\n<li>Lebenszyklusanalyse (Definitionen, Methoden, Anwendung)&nbsp;</li>\n<li>Nachhaltiges Produktdesign (Anforderungen Prinzipien, Vorgaben)&nbsp;</li>\n<li>Materialstr&ouml;me (Effizienz, Recyclingf&auml;higkeit, Quellen und Schnittstellen zu anderen Gesetzten, REACH, RoHS)&nbsp;</li>\n</ul>",
      "bibliographie": "<p>Ellen MacArthur Foundation. (2013). Towards the circular economy: Economic and business rationale for an accelerated transition &nbsp;</p>",
      "empfLehrmittel": "<p>Vorlesung, &Uuml;bungen, Selbststudium, eigenst&auml;ndige Analyse als Projektarbeit (Selbststudium)&nbsp;</p>",
      "bemerkungKurs": "<p>Der Kurs findet in den ersten 6 Wochen des Semesters mit 4 Lektionen pro Woche statt.</p>",
      "leistungsnachweis": "<p>Projekt und Modulschlusspr&uuml;fung</p>",
